<Window x:Class="Taskato.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Taskato 设置"
        Width="400" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Border CornerRadius="16"
            Background="{StaticResource WindowBackgroundBrush}"
            BorderBrush="#266366F1" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="10" Opacity="0.5"/>
        </Border.Effect>

        <StackPanel>
            <!-- ========== 标题栏 ========== -->
            <Border Background="#08FFFFFF"
                    BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,0,0,1"
                    CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="20,14">
                    <TextBlock Text="⚙ 设置" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <Ellipse Width="14" Height="14" Fill="#EF4444" Cursor="Hand"
                             HorizontalAlignment="Right" VerticalAlignment="Center"
                             MouseLeftButtonDown="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- ========== 设置内容 ========== -->
            <StackPanel Margin="20">

                <!-- 主题颜色 -->
                <TextBlock Text="🎨 主题颜色" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,12"/>
                <WrapPanel x:Name="ColorPalette" Margin="0,0,0,24">
                    <!-- 颜色选项会在代码后台动态创建 -->
                </WrapPanel>

                <!-- 番茄钟时长 -->
                <TextBlock Text="⏱ 番茄钟时长" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,12"/>

                <!-- 工作时长 -->
                <Border Background="#0AFFFFFF" CornerRadius="10" Padding="16,12" Margin="0,0,0,8">
                    <Grid>
                        <TextBlock Text="工作时长" FontSize="14"
                                   Foreground="#CCCCCC" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="−" Width="28" Height="28" FontSize="16" Cursor="Hand"
                                    Click="DecWorkTime_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#0FFFFFFF"/>
                                        <Setter Property="Foreground" Value="#CCCCCC"/>
                                        <Setter Property="BorderBrush" Value="#26FFFFFF"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <TextBlock x:Name="WorkTimeText" Text="25 min" FontSize="16" FontWeight="SemiBold"
                                       Foreground="#E0E0E0" MinWidth="55" TextAlignment="Center"
                                       VerticalAlignment="Center" Margin="8,0"/>
                            <Button Content="+" Width="28" Height="28" FontSize="16" Cursor="Hand"
                                    Click="IncWorkTime_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#0FFFFFFF"/>
                                        <Setter Property="Foreground" Value="#CCCCCC"/>
                                        <Setter Property="BorderBrush" Value="#26FFFFFF"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 休息时长 -->
                <Border Background="#0AFFFFFF" CornerRadius="10" Padding="16,12" Margin="0,0,0,24">
                    <Grid>
                        <TextBlock Text="休息时长" FontSize="14"
                                   Foreground="#CCCCCC" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="−" Width="28" Height="28" FontSize="16" Cursor="Hand"
                                    Click="DecRestTime_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#0FFFFFFF"/>
                                        <Setter Property="Foreground" Value="#CCCCCC"/>
                                        <Setter Property="BorderBrush" Value="#26FFFFFF"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <TextBlock x:Name="RestTimeText" Text="5 min" FontSize="16" FontWeight="SemiBold"
                                       Foreground="#E0E0E0" MinWidth="55" TextAlignment="Center"
                                       VerticalAlignment="Center" Margin="8,0"/>
                            <Button Content="+" Width="28" Height="28" FontSize="16" Cursor="Hand"
                                    Click="IncRestTime_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#0FFFFFFF"/>
                                        <Setter Property="Foreground" Value="#CCCCCC"/>
                                        <Setter Property="BorderBrush" Value="#26FFFFFF"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 开机自启 -->
                <TextBlock Text="🚀 系统" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,12"/>
                <Border Background="#0AFFFFFF" CornerRadius="10" Padding="16,12" Margin="0,0,0,8">
                    <Grid>
                        <TextBlock Text="开机自启动" FontSize="14"
                                   Foreground="#CCCCCC" VerticalAlignment="Center"/>
                        <CheckBox x:Name="AutoStartCheckBox"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Checked="AutoStartCheckBox_Changed"
                                  Unchecked="AutoStartCheckBox_Changed"/>
                    </Grid>
                </Border>
                
                <Border Background="#0AFFFFFF" CornerRadius="10" Padding="16,12" Margin="0,0,0,12">
                    <Grid>
                        <TextBlock Text="继续工作时自动开始倒计时" FontSize="14"
                                   Foreground="#CCCCCC" VerticalAlignment="Center"/>
                        <CheckBox x:Name="AutoStartNextCheckBox"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Checked="AutoStartNextCheckBox_Changed"
                                  Unchecked="AutoStartNextCheckBox_Changed"/>
                    </Grid>
                </Border>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
