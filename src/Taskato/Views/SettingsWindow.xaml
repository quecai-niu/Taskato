<Window x:Class="Taskato.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Taskato 设置"
        Width="700" Height="620"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="40"
                      GlassFrameThickness="0"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="SettingsNavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#12FFFFFF"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Style="{StaticResource SubWindowBorderStyle}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ========== 标题栏 ========== -->
            <Border Grid.Row="0" Background="Transparent"
                    CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="20,14">
                    <TextBlock Text="⚙ 设置" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <!-- 优化：使用 Q弹果冻胶囊窗口控制 (仅退出) -->
                    <Border HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource JellyCapsuleStyle}"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="min" Style="{StaticResource JellyWinBtn}" Click="MinimizeButton_Click"/>
                            <Button Content="max" Style="{StaticResource JellyWinBtn}" Click="MaximizeButton_Click"/>
                            <Button Content="exit" Style="{StaticResource JellyWinCloseBtn}" Click="CloseButton_Click"/>
                        </StackPanel>
                    </Border>

                </Grid>
            </Border>

            <!-- ========== 设置内容（左侧目录 + 右侧连续滚动） ========== -->
            <Grid Grid.Row="1" Margin="20,8,20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="126"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#08FFFFFF"
                        BorderBrush="#12FFFFFF"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10"
                        VerticalAlignment="Top">
                    <StackPanel>
                        <Button x:Name="NavThemeButton" Content="主题颜色" Tag="Theme"
                                Click="SectionNavButton_Click"
                                Style="{StaticResource SettingsNavButtonStyle}"/>
                        <Button x:Name="NavPomodoroButton" Content="番茄钟时长" Tag="Pomodoro"
                                Click="SectionNavButton_Click"
                                Style="{StaticResource SettingsNavButtonStyle}"/>
                        <Button x:Name="NavSystemButton" Content="系统" Tag="System"
                                Click="SectionNavButton_Click"
                                Style="{StaticResource SettingsNavButtonStyle}"/>
                        <Button x:Name="NavSummaryButton" Content="每日总结" Tag="Summary"
                                Click="SectionNavButton_Click"
                                Style="{StaticResource SettingsNavButtonStyle}"/>
                        <Button x:Name="NavSoundButton" Content="提示音" Tag="Sound"
                                Click="SectionNavButton_Click"
                                Style="{StaticResource SettingsNavButtonStyle}"/>
                        <Button x:Name="NavFeishuButton" Content="飞书通知" Tag="Feishu"
                                Click="SectionNavButton_Click"
                                Style="{StaticResource SettingsNavButtonStyle}"/>
                    </StackPanel>
                </Border>

                <ScrollViewer x:Name="SettingsScrollViewer"
                              Grid.Column="1"
                              VerticalScrollBarVisibility="Auto"
                              IsDeferredScrollingEnabled="True"
                              ScrollChanged="SettingsScrollViewer_ScrollChanged">
                <StackPanel x:Name="SettingsContentPanel" Margin="20,0,0,0">

                <!-- 主题颜色 -->
                <TextBlock x:Name="ThemeSection" Text="🎨 主题颜色" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,12"/>
                <WrapPanel x:Name="ColorPalette" Margin="0,0,0,24">
                    <!-- 颜色选项会在代码后台动态创建 -->
                </WrapPanel>

                <!-- 番茄钟时长 -->
                <TextBlock x:Name="PomodoroSection" Text="⏱ 番茄钟时长" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,12"/>

                <!-- 工作时长 -->
                <Border Background="#0AFFFFFF" CornerRadius="10" Padding="16,12" Margin="0,0,0,8">
                    <Grid>
                        <TextBlock Text="工作时长" FontSize="14"
                                   Foreground="#CCCCCC" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="−" Width="28" Height="28" FontSize="16" Cursor="Hand"
                                    Click="DecWorkTime_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#0FFFFFFF"/>
                                        <Setter Property="Foreground" Value="#CCCCCC"/>
                                        <Setter Property="BorderBrush" Value="#26FFFFFF"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <TextBlock x:Name="WorkTimeText" Text="25 min" FontSize="16" FontWeight="SemiBold"
                                       Foreground="#E0E0E0" MinWidth="55" TextAlignment="Center"
                                       VerticalAlignment="Center" Margin="8,0"/>
                            <Button Content="+" Width="28" Height="28" FontSize="16" Cursor="Hand"
                                    Click="IncWorkTime_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#0FFFFFFF"/>
                                        <Setter Property="Foreground" Value="#CCCCCC"/>
                                        <Setter Property="BorderBrush" Value="#26FFFFFF"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 休息时长 -->
                <Border Background="#0AFFFFFF" CornerRadius="10" Padding="16,12" Margin="0,0,0,24">
                    <Grid>
                        <TextBlock Text="休息时长" FontSize="14"
                                   Foreground="#CCCCCC" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="−" Width="28" Height="28" FontSize="16" Cursor="Hand"
                                    Click="DecRestTime_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#0FFFFFFF"/>
                                        <Setter Property="Foreground" Value="#CCCCCC"/>
                                        <Setter Property="BorderBrush" Value="#26FFFFFF"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <TextBlock x:Name="RestTimeText" Text="5 min" FontSize="16" FontWeight="SemiBold"
                                       Foreground="#E0E0E0" MinWidth="55" TextAlignment="Center"
                                       VerticalAlignment="Center" Margin="8,0"/>
                            <Button Content="+" Width="28" Height="28" FontSize="16" Cursor="Hand"
                                    Click="IncRestTime_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#0FFFFFFF"/>
                                        <Setter Property="Foreground" Value="#CCCCCC"/>
                                        <Setter Property="BorderBrush" Value="#26FFFFFF"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 开机自启 -->
                <TextBlock x:Name="SystemSection" Text="🚀 系统" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,12"/>
                <Border Background="#0AFFFFFF" CornerRadius="10" Padding="16,12" Margin="0,0,0,8">
                    <Grid>
                        <TextBlock Text="开机自启动" FontSize="14"
                                   Foreground="#CCCCCC" VerticalAlignment="Center"/>
                        <CheckBox x:Name="AutoStartCheckBox"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Checked="AutoStartCheckBox_Changed"
                                  Unchecked="AutoStartCheckBox_Changed"/>
                    </Grid>
                </Border>
                
                <Border Background="#0AFFFFFF" CornerRadius="10" Padding="16,12" Margin="0,0,0,8">
                    <Grid>
                        <TextBlock Text="继续工作时自动开始倒计时" FontSize="14"
                                   Foreground="#CCCCCC" VerticalAlignment="Center"/>
                        <CheckBox x:Name="AutoStartNextCheckBox"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Checked="AutoStartNextCheckBox_Changed"
                                  Unchecked="AutoStartNextCheckBox_Changed"/>
                    </Grid>
                </Border>

                <!-- 弹窗计时器开关 -->
                <Border Background="#0AFFFFFF" CornerRadius="10" Padding="16,12" Margin="0,0,0,8">
                    <Grid>
                        <TextBlock Text="开启提醒弹窗内的计时器" FontSize="14"
                                   Foreground="#CCCCCC" VerticalAlignment="Center"/>
                        <CheckBox x:Name="ToastTimerCheckBox"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Checked="ToastTimerCheckBox_Changed"
                                  Unchecked="ToastTimerCheckBox_Changed"/>
                    </Grid>
                </Border>

                <!-- 弹窗操作按钮延迟 -->
                <Border Background="#0AFFFFFF" CornerRadius="10" Padding="16,12" Margin="0,0,0,8">
                    <Grid>
                        <TextBlock Text="提醒弹窗按钮延迟启用" FontSize="14"
                                   Foreground="#CCCCCC" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="−" Width="28" Height="28" FontSize="16" Cursor="Hand"
                                    Click="DecToastDelay_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#0FFFFFFF"/>
                                        <Setter Property="Foreground" Value="#CCCCCC"/>
                                        <Setter Property="BorderBrush" Value="#26FFFFFF"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <TextBlock x:Name="ToastDelayText" Text="1.5 秒" FontSize="16" FontWeight="SemiBold"
                                       Foreground="#E0E0E0" MinWidth="65" TextAlignment="Center"
                                       VerticalAlignment="Center" Margin="8,0"/>
                            <Button Content="+" Width="28" Height="28" FontSize="16" Cursor="Hand"
                                    Click="IncToastDelay_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#0FFFFFFF"/>
                                        <Setter Property="Foreground" Value="#CCCCCC"/>
                                        <Setter Property="BorderBrush" Value="#26FFFFFF"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 多组番茄钟开关 -->
                <Border Background="#0AFFFFFF" CornerRadius="10" Padding="16,12" Margin="0,0,0,8">
                    <Grid>
                        <TextBlock Text="开启多组番茄钟模式 (Alpha)" FontSize="14"
                                   Foreground="#CCCCCC" VerticalAlignment="Center"/>
                        <CheckBox x:Name="MultiPomodoroCheckBox"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Checked="MultiPomodoroCheckBox_Changed"
                                  Unchecked="MultiPomodoroCheckBox_Changed"/>
                    </Grid>
                </Border>

                <!-- 每日总结 -->
                <TextBlock x:Name="SummarySection" Text="📊 每日总结" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,8,0,12"/>
                <Border Background="#0AFFFFFF" CornerRadius="10" Padding="16,12" Margin="0,0,0,24">
                    <Grid>
                        <TextBlock Text="跨天时自动弹出昨日总结" FontSize="14"
                                   Foreground="#CCCCCC" VerticalAlignment="Center"/>
                        <CheckBox x:Name="AutoDailySummaryCheckBox"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Checked="AutoDailySummaryCheckBox_Changed"
                                  Unchecked="AutoDailySummaryCheckBox_Changed"/>
                    </Grid>
                </Border>

                <!-- 提示音选择 -->
                <TextBlock x:Name="SoundSection" Text="🔔 提示音" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,8,0,12"/>
                <Border Background="#0AFFFFFF" CornerRadius="10" Padding="16,12" Margin="0,0,0,24">
                    <StackPanel>
                        <!-- 用 RadioButton 组代替 ComboBox，避免 WPF 默认白色背景污染深色主题 -->
                        <RadioButton x:Name="Sound0" Content="🔇  无声"
                                     GroupName="SoundGroup" Tag="0"
                                     Foreground="#E0E0E0" FontSize="13" Margin="0,4"
                                     Checked="SoundRadio_Checked" Style="{StaticResource {x:Type RadioButton}}"/>
                        <RadioButton x:Name="Sound1" Content="🔔  Windows Notify（清脆响亮）"
                                     GroupName="SoundGroup" Tag="1"
                                     Foreground="#E0E0E0" FontSize="13" Margin="0,4"
                                     Checked="SoundRadio_Checked" Style="{StaticResource {x:Type RadioButton}}"/>
                        <RadioButton x:Name="Sound2" Content="🔔  Windows Ding（简短清脆）"
                                     GroupName="SoundGroup" Tag="2"
                                     Foreground="#E0E0E0" FontSize="13" Margin="0,4"
                                     Checked="SoundRadio_Checked" Style="{StaticResource {x:Type RadioButton}}"/>
                        <RadioButton x:Name="Sound3" Content="🔔  Windows Background（低沉厚重）"
                                     GroupName="SoundGroup" Tag="3"
                                     Foreground="#E0E0E0" FontSize="13" Margin="0,4"
                                     Checked="SoundRadio_Checked" Style="{StaticResource {x:Type RadioButton}}"/>
                        <RadioButton x:Name="Sound4" Content="🔔  Chimes（风铃悠扬）"
                                     GroupName="SoundGroup" Tag="4"
                                     Foreground="#E0E0E0" FontSize="13" Margin="0,4"
                                     Checked="SoundRadio_Checked" Style="{StaticResource {x:Type RadioButton}}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <RadioButton x:Name="Sound5" Content="🎵  自定义音效"
                                         GroupName="SoundGroup" Tag="5"
                                         Foreground="#E0E0E0" FontSize="13" VerticalAlignment="Center"
                                         Checked="SoundRadio_Checked" Style="{StaticResource {x:Type RadioButton}}"/>
                            <Button x:Name="SelectCustomSoundBtn" Content="浏览..." Margin="12,0,0,0"
                                    Padding="10,4" FontSize="11"
                                    Click="SelectCustomSoundBtn_Click"
                                    Style="{StaticResource SecondaryButton}"
                                    Visibility="Collapsed"/>
                            <TextBlock x:Name="CustomSoundPathText" Text="未选择" 
                                       Foreground="{StaticResource TextMutedBrush}" 
                                       FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"
                                       MaxWidth="150" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <Button x:Name="PreviewSoundBtn" Content="▶ 试听" Margin="0,10,0,0"
                                HorizontalAlignment="Left" Padding="16,6"
                                Click="PreviewSoundBtn_Click"
                                Style="{StaticResource SecondaryButton}"/>
                    </StackPanel>
                </Border>

                <!-- 飞书通知 -->
                <TextBlock x:Name="FeishuSection" Text="🔗 飞书通知" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,8,0,12"/>
                <Border Background="#0AFFFFFF" CornerRadius="10" Padding="16,12" Margin="0,0,0,8">
                    <Grid>
                        <TextBlock Text="启用飞书通知" FontSize="14"
                                   Foreground="#CCCCCC" VerticalAlignment="Center"/>
                        <CheckBox x:Name="FeishuEnabledCheckBox"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Checked="FeishuEnabledCheckBox_Changed"
                                  Unchecked="FeishuEnabledCheckBox_Changed"/>
                    </Grid>
                </Border>
                <Border Background="#0AFFFFFF" CornerRadius="10" Padding="16,12" Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <TextBlock Text="Webhook URL" FontSize="14"
                                       Foreground="#CCCCCC" VerticalAlignment="Center"/>
                            <Button x:Name="FeishuHelpButton"
                                    Content="如何获取 Webhook？"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Padding="12,4"
                                    FontSize="11"
                                    Cursor="Hand"
                                    Click="FeishuHelpButton_Click"
                                    Style="{StaticResource SecondaryButton}"/>
                        </Grid>
                        <TextBox x:Name="FeishuWebhookUrlBox"
                                 Grid.Row="1" Margin="0,8,0,0"
                                 Foreground="#E0E0E0"
                                 CaretBrush="#E0E0E0"
                                 TextChanged="FeishuWebhookUrlBox_TextChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="#15FFFFFF"/>
                                    <Setter Property="BorderBrush" Value="#26FFFFFF"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Padding" Value="8,6"/>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                </Border>
                <Border x:Name="FeishuHelpPanel"
                        Visibility="Collapsed"
                        Background="#08FFFFFF"
                        BorderBrush="#16FFFFFF"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16,12"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="如何获取 Webhook？"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="飞书电脑版客户端：群设置 -> 群机器人 -> 添加自定义机器人 -> 复制 Webhook"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   LineHeight="20"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="示例：https://open.feishu.cn/open-apis/bot/v2/hook/XXXXXXXX"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <Border Background="#0AFFFFFF" CornerRadius="10" Padding="16,12" Margin="0,0,0,8">
                    <Grid>
                        <TextBlock Text="首次配置引导" FontSize="14"
                                   Foreground="#CCCCCC" VerticalAlignment="Center"/>
                        <Button x:Name="FeishuGuidePreviewButton"
                                Content="查看引导"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Padding="16,6"
                                FontSize="12"
                                Cursor="Hand"
                                Click="FeishuGuidePreviewButton_Click"
                                Style="{StaticResource SecondaryButton}"/>
                    </Grid>
                </Border>
                <Border Background="#0AFFFFFF" CornerRadius="10" Padding="16,12" Margin="0,0,0,8">
                    <Grid>
                        <TextBlock Text="测试发送" FontSize="14"
                                   Foreground="#CCCCCC" VerticalAlignment="Center"/>
                        <Button x:Name="FeishuTestBtn" Content="测试"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Padding="16,6" FontSize="12" Cursor="Hand"
                                Click="FeishuTestBtn_Click"
                                Style="{StaticResource SecondaryButton}"/>
                    </Grid>
                </Border>
                <Border Background="#0AFFFFFF" CornerRadius="10" Padding="16,12" Margin="0,0,0,8">
                    <Grid>
                        <TextBlock Text="工作完成时通知" FontSize="14"
                                   Foreground="#CCCCCC" VerticalAlignment="Center"/>
                        <CheckBox x:Name="FeishuNotifyWorkCheckBox"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Checked="FeishuNotifyWorkCheckBox_Changed"
                                  Unchecked="FeishuNotifyWorkCheckBox_Changed"/>
                    </Grid>
                </Border>
                <Border Background="#0AFFFFFF" CornerRadius="10" Padding="16,12" Margin="0,0,0,8">
                    <Grid>
                        <TextBlock Text="结束时重复发送 3 次（间隔 3 秒）" FontSize="14"
                                   Foreground="#CCCCCC" VerticalAlignment="Center"/>
                        <CheckBox x:Name="FeishuRepeatCheckBox"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Checked="FeishuRepeatCheckBox_Changed"
                                  Unchecked="FeishuRepeatCheckBox_Changed"/>
                    </Grid>
                </Border>
                <Border Background="#0AFFFFFF" CornerRadius="10" Padding="16,12" Margin="0,0,0,8">
                    <Grid>
                        <TextBlock Text="休息过半时提醒" FontSize="14"
                                   Foreground="#CCCCCC" VerticalAlignment="Center"/>
                        <CheckBox x:Name="FeishuRestHalfwayCheckBox"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Checked="FeishuRestHalfwayCheckBox_Changed"
                                  Unchecked="FeishuRestHalfwayCheckBox_Changed"/>
                    </Grid>
                </Border>
                <Border Background="#0AFFFFFF" CornerRadius="10" Padding="16,12" Margin="0,0,0,24">
                    <Grid>
                        <TextBlock Text="休息完成时通知" FontSize="14"
                                   Foreground="#CCCCCC" VerticalAlignment="Center"/>
                        <CheckBox x:Name="FeishuNotifyRestCheckBox"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Checked="FeishuNotifyRestCheckBox_Changed"
                                  Unchecked="FeishuNotifyRestCheckBox_Changed"/>
                    </Grid>
                </Border>
            </StackPanel>
            </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
