<Window x:Class="Taskato.Views.TaskDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="任务详情"
        Width="380" MinHeight="240"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- 弹窗进场动画 -->
        <Storyboard x:Key="PopInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="15" To="0" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Border CornerRadius="16"
            Background="#E61A1A1A"
            BorderBrush="#336366F1" BorderThickness="1"
            RenderTransformOrigin="0.5,0.5">
        
        <Border.RenderTransform>
            <TranslateTransform Y="0"/>
        </Border.RenderTransform>
        
        <Border.Effect>
            <!-- 窗体泛光阴影 -->
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="15" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. 标题栏 -->
            <Border Grid.Row="0" Background="#08FFFFFF"
                    BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,0,0,1"
                    CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,12">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="{DynamicResource ThemePrimaryBrush}" Margin="0,0,8,0">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="{DynamicResource ThemePrimaryColor}" BlurRadius="8" ShadowDepth="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock Text="任务详情" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <!-- 关闭按钮 (V2 可爱风格) -->
                    <Button Content="✕" Style="{StaticResource CuteWinCloseBtn}" 
                            HorizontalAlignment="Right" Click="CloseButton_Click"/>

                </Grid>
            </Border>

            <!-- 2. 内容区 -->
            <StackPanel Grid.Row="1" Margin="24,10,24,20">
                
                <!-- 标签栏（只读显示当前提取出的标签） -->
                <ItemsControl ItemsSource="{Binding Tags}" Margin="0,0,0,16">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#33A855F7" CornerRadius="100" Padding="10,4" Margin="0,0,8,4">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#D8B4FE">
                                    <Run Text="#" Foreground="#99D8B4FE"/>
                                    <Run Text="{Binding}"/>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 优先级选择 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="优先级：" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,0" FontSize="13"/>
                    <RadioButton Content="无" IsChecked="{Binding Priority, Converter={StaticResource IntToBoolConverter}, ConverterParameter=0}" Style="{StaticResource DarkRadioButton}" Margin="0,0,12,0"/>
                    <RadioButton Content="中" IsChecked="{Binding Priority, Converter={StaticResource IntToBoolConverter}, ConverterParameter=1}" Style="{StaticResource DarkRadioButton}" Margin="0,0,12,0"/>
                    <RadioButton Content="高" IsChecked="{Binding Priority, Converter={StaticResource IntToBoolConverter}, ConverterParameter=2}" Style="{StaticResource DarkRadioButton}" Margin="0,0,12,0"/>
                    <RadioButton Content="紧急" IsChecked="{Binding Priority, Converter={StaticResource IntToBoolConverter}, ConverterParameter=3}" Style="{StaticResource DarkRadioButton}"/>
                </StackPanel>

                <!-- 可编辑文本区：使用 ScrollViewer 包裹防止内容过多撑出窗口 -->
                <ScrollViewer MaxHeight="350" VerticalScrollBarVisibility="Auto">
                    <TextBox Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             FontSize="16"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Background="Transparent"
                             BorderThickness="0"
                             CaretBrush="White"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             Margin="0,0,5,0"/>
                </ScrollViewer>

                <!-- 底部操作按钮 -->
                <Grid Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="取消" Style="{StaticResource SecondaryButton}" Click="CancelButton_Click" Margin="0,0,8,0" Padding="0,10"/>
                    <Button Grid.Column="1" Content="保存修改" Style="{StaticResource PrimaryButton}" Click="SaveButton_Click" Margin="8,0,0,0" Padding="0,10"/>
                </Grid>
                           
            </StackPanel>

            <!-- 3. 底栏状态与时间 -->
            <Border Grid.Row="2" BorderThickness="0,1,0,0"
                    BorderBrush="{StaticResource SeparatorBrush}"
                    Margin="24,0,24,24" Padding="0,16,0,0">
                <Grid>
                    <StackPanel Orientation="Vertical">
                        <TextBlock FontSize="12" Margin="0,0,0,4">
                            <Run Text="📅 创建时间：" Foreground="{StaticResource TextMutedBrush}" />
                            <Run Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Foreground="{StaticResource TextMutedBrush}" />
                        </TextBlock>
                        <TextBlock FontSize="12" Margin="0,4,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="✅ 完成时间：" Foreground="{StaticResource TextMutedBrush}" />
                            <Run Text="{Binding CompletedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Foreground="{StaticResource TextMutedBrush}" />
                        </TextBlock>
                    </StackPanel>

                    <!-- 状态印章徽章 -->
                    <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                            Width="36" Height="36" CornerRadius="8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <!-- 未完成：灰显沙漏 -->
                                <Setter Property="Background" Value="#1AFFFFFF"/>
                                <Setter Property="BorderBrush" Value="#33FFFFFF"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <!-- 已完成：绿色对钩 -->
                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                        <Setter Property="Background" Value="#1A22C55E"/>
                                        <Setter Property="BorderBrush" Value="#3322C55E"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="⏳"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                    <Setter Property="ToolTip" Value="目前为未完成状态"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                            <Setter Property="Text" Value="✓"/>
                                            <Setter Property="Foreground" Value="#22C55E"/>
                                            <Setter Property="ToolTip" Value="该任务已完成结算"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>

</Window>
