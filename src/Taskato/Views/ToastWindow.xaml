<Window x:Class="Taskato.Views.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Taskato 通知"
        Width="360" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded">
    <!--
        Topmost="True": 始终显示在最前面（即使用户在使用其他程序）
        ShowInTaskbar="False": 不在任务栏显示
        WindowStartupLocation="Manual": 手动轮换定位到屏幕四角
    -->

    <!-- 弹窗主体 — 熔金流动边框 + 闪卡扫光 -->
    <Grid Margin="4">
        <Border CornerRadius="22"
                BorderThickness="3"
                SnapsToDevicePixels="True">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <LinearGradientBrush.RelativeTransform>
                        <TranslateTransform x:Name="GoldFlowTransform" X="-0.18" Y="0"/>
                    </LinearGradientBrush.RelativeTransform>
                    <GradientStop Color="#5C3309" Offset="0.00"/>
                    <GradientStop Color="#D5851D" Offset="0.18"/>
                    <GradientStop Color="#FFF1AA" Offset="0.38"/>
                    <GradientStop Color="#F1B23C" Offset="0.56"/>
                    <GradientStop Color="#805114" Offset="0.74"/>
                    <GradientStop Color="#FFD76F" Offset="0.88"/>
                    <GradientStop Color="#5C3309" Offset="1.00"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Effect>
                <DropShadowEffect Color="#F5B83D" BlurRadius="42" ShadowDepth="0" Opacity="0.36"/>
            </Border.Effect>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetName="GoldFlowTransform"
                                             Storyboard.TargetProperty="X"
                                             From="-0.24" To="0.24" Duration="0:0:4.4"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>

            <Grid ClipToBounds="True">
                <Border CornerRadius="18"
                        Padding="28">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#F21C1C30" Offset="0"/>
                            <GradientStop Color="#FA141424" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="10" Opacity="0.6"/>
                    </Border.Effect>

                    <!-- 弹窗内容 -->
                    <StackPanel HorizontalAlignment="Center">
                        <!-- 番茄图标（会上下弹跳） -->
                        <TextBlock x:Name="ToastIcon" Text="🍅" FontSize="48" FontFamily="Segoe UI Emoji"
                                   Foreground="{DynamicResource ThemePrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock.RenderTransform>
                                <TranslateTransform x:Name="iconTransform"/>
                            </TextBlock.RenderTransform>
                            <TextBlock.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetName="iconTransform"
                                                             Storyboard.TargetProperty="Y"
                                                             From="0" To="-6" Duration="0:0:1"
                                                             EasingFunction="{x:Null}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </TextBlock.Triggers>
                        </TextBlock>

                        <!-- 标题文字 -->
                        <TextBlock x:Name="TitleText" FontSize="20" FontWeight="Bold"
                                   Foreground="#E0E0E0" HorizontalAlignment="Center"
                                   Margin="0,0,0,8" TextWrapping="Wrap" TextAlignment="Center"/>

                        <!-- 副标题文字 -->
                        <TextBlock x:Name="SubtitleText" FontSize="14"
                                   Foreground="#888888" HorizontalAlignment="Center"
                                   Margin="0,0,0,8" TextWrapping="Wrap" TextAlignment="Center"/>

                        <!-- 计时器显示 (弹窗已出现时长) -->
                        <TextBlock x:Name="ElapsedTimerText" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#BBBBBB" HorizontalAlignment="Center"
                                   Margin="0,0,0,16" Visibility="Collapsed"/>

                        <!-- 操作按钮延迟提示 -->
                        <TextBlock x:Name="ActionDelayText" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#F5CC67" HorizontalAlignment="Center"
                                   Margin="0,0,0,12" Visibility="Collapsed"/>

                        <!-- 操作按钮组 -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <!-- 休息按钮（主色调） -->
                            <Button x:Name="RestButton"
                                    Style="{StaticResource PrimaryButton}"
                                    Content="☕ 休息一下"
                                    Click="RestButton_Click"
                                    Margin="0,0,10,0" Padding="24,10"/>

                            <!-- 继续工作按钮 -->
                            <Button x:Name="ContinueButton"
                                    Style="{StaticResource SecondaryButton}"
                                    Content="💪 继续工作"
                                    Click="ContinueButton_Click"
                                    Padding="24,10"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border CornerRadius="18"
                        IsHitTestVisible="False"
                        Opacity="0.26">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <LinearGradientBrush.RelativeTransform>
                                <TransformGroup>
                                    <RotateTransform Angle="18" CenterX="0.5" CenterY="0.5"/>
                                    <TranslateTransform x:Name="GoldSheenTransform" X="-1.22"/>
                                </TransformGroup>
                            </LinearGradientBrush.RelativeTransform>
                            <GradientStop Color="#00FFFFFF" Offset="0.00"/>
                            <GradientStop Color="#00FFFFFF" Offset="0.34"/>
                            <GradientStop Color="#CFFFF7C4" Offset="0.47"/>
                            <GradientStop Color="#55FFFFFF" Offset="0.52"/>
                            <GradientStop Color="#00FFFFFF" Offset="0.68"/>
                            <GradientStop Color="#00FFFFFF" Offset="1.00"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="GoldSheenTransform"
                                                     Storyboard.TargetProperty="X"
                                                     From="-1.22" To="1.22"
                                                     BeginTime="0:0:0.35"
                                                     Duration="0:0:3.9"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
