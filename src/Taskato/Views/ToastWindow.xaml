<Window x:Class="Taskato.Views.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Taskato 通知"
        Width="320" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded">
    <!--
        Topmost="True": 始终显示在最前面（即使用户在使用其他程序）
        ShowInTaskbar="False": 不在任务栏显示
        WindowStartupLocation="Manual": 手动定位到屏幕右下角
    -->

    <!-- 弹窗主体 — 圆角毛玻璃风格 -->
    <Border CornerRadius="16" Padding="28"
            BorderBrush="#336366F1" BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F21A1A2E" Offset="0"/>
                <GradientStop Color="#FA16162A" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="10" Opacity="0.6"/>
        </Border.Effect>

        <!-- 弹窗内容 -->
        <StackPanel HorizontalAlignment="Center">
            <!-- 番茄图标（会上下弹跳） -->
            <TextBlock x:Name="ToastIcon" Text="🍅" FontSize="48"
                       HorizontalAlignment="Center" Margin="0,0,0,16">
                <TextBlock.RenderTransform>
                    <TranslateTransform x:Name="iconTransform"/>
                </TextBlock.RenderTransform>
                <TextBlock.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetName="iconTransform"
                                                 Storyboard.TargetProperty="Y"
                                                 From="0" To="-6" Duration="0:0:1"
                                                 EasingFunction="{x:Null}"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TextBlock.Triggers>
            </TextBlock>

            <!-- 标题文字 -->
            <TextBlock x:Name="TitleText" FontSize="20" FontWeight="Bold"
                       Foreground="#E0E0E0" HorizontalAlignment="Center"
                       Margin="0,0,0,8" TextWrapping="Wrap" TextAlignment="Center"/>

            <!-- 副标题文字 -->
            <TextBlock x:Name="SubtitleText" FontSize="14"
                       Foreground="#888888" HorizontalAlignment="Center"
                       Margin="0,0,0,24" TextWrapping="Wrap" TextAlignment="Center"/>

            <!-- 操作按钮组 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <!-- 休息按钮（主色调） -->
                <Button x:Name="RestButton"
                        Style="{StaticResource PrimaryButton}"
                        Content="☕ 休息一下"
                        Click="RestButton_Click"
                        Margin="0,0,10,0" Padding="24,10"/>

                <!-- 继续工作按钮 -->
                <Button x:Name="ContinueButton"
                        Style="{StaticResource SecondaryButton}"
                        Content="💪 继续工作"
                        Click="ContinueButton_Click"
                        Padding="24,10"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
