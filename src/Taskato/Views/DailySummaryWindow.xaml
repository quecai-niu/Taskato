<Window x:Class="Taskato.Views.DailySummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Taskato.Converters"
        Title="每日总结"
        Width="560" Height="450"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="80" ResizeBorderThickness="40" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <converters:PriorityToLabelConverter x:Key="PriorityToLabelConverter"/>
    </Window.Resources>

    <Border Style="{StaticResource SubWindowBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 + 日期切换 -->
            <Border Background="Transparent" CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="20,14">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="◀" Style="{StaticResource SecondaryButton}"
                                Command="{Binding GoPrevCommand}"
                                Width="32" Height="32" Padding="0" FontSize="14"
                                Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding DateDisplay}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button Content="▶" Style="{StaticResource SecondaryButton}"
                                Command="{Binding GoNextCommand}"
                                Width="32" Height="32" Padding="0" FontSize="14"
                                Margin="10,0,0,0"/>
                    </StackPanel>

                    <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                            Style="{StaticResource JellyCapsuleStyle}"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="min" Style="{StaticResource JellyWinBtn}" Click="MinimizeButton_Click"/>
                            <Button Content="max" Style="{StaticResource JellyWinBtn}" Click="MaximizeButton_Click"/>
                            <Button Content="exit" Style="{StaticResource JellyWinCloseBtn}" Click="CloseButton_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- 总结内容 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,0,20,12">
                <StackPanel>
                    <TextBlock Text="{Binding SummaryLine}" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap" Margin="0,12,0,8"/>

                    <Border Height="1" Background="{StaticResource SeparatorBrush}" Margin="0,0,0,12"/>

                    <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="统计：完成 {0} | 高优先级完成 {1}">
                                <Binding Path="CompletedCount"/>
                                <Binding Path="HighPriorityCompleted"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>

                    <TextBlock Text="已完成" FontSize="13" FontWeight="SemiBold"
                               Foreground="#4ADE80" Margin="0,12,0,6"/>
                    <ItemsControl ItemsSource="{Binding CompletedTasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0A22C55E" CornerRadius="6"
                                        Padding="10,6" Margin="0,0,0,4">
                                    <TextBlock FontSize="13" Foreground="{StaticResource TextPrimaryBrush}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0}  {1}">
                                                <Binding Path="Priority" Converter="{StaticResource PriorityToLabelConverter}"/>
                                                <Binding Path="Title"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>

            <!-- 底部按钮 -->
            <Border Grid.Row="2" BorderBrush="{StaticResource SeparatorBrush}"
                    BorderThickness="0,1,0,0" CornerRadius="0,0,16,16">
                <StackPanel Orientation="Horizontal" Margin="20,14" HorizontalAlignment="Right">
                    <Button Content="复制总结" Style="{StaticResource SecondaryButton}"
                            Command="{Binding CopyCommand}" Padding="16,8" Margin="0,0,10,0"/>
                    <Button Content="导出文本" Style="{StaticResource PrimaryButton}"
                            Command="{Binding ExportCommand}" Padding="16,8"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
