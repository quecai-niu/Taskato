<Window x:Class="Taskato.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Taskato.Converters"
        xmlns:utils="clr-namespace:Taskato.Utils"
        Title="历史任务查询"
        Width="640" Height="630"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="40"
                      GlassFrameThickness="0" 
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    <!--
        这个窗体会以对话框模式打开（ShowDialog），
        关闭后焦点回到主窗体。
    -->
    <Window.Resources>
        <Style x:Key="HistoryFilterChipStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="chip"
                                CornerRadius="8"
                                Padding="12,6"
                                Background="#1418273A"
                                BorderBrush="#22FFFFFF"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="chip" Property="Background" Value="#1F6366F1"/>
                                <Setter TargetName="chip" Property="BorderBrush" Value="#556366F1"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter TargetName="chip" Property="Background" Value="#336366F1"/>
                                <Setter TargetName="chip" Property="BorderBrush" Value="#806366F1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HistoryComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="itemBd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Margin="4,2"
                                Padding="{TemplateBinding Padding}"
                                TextElement.Foreground="{TemplateBinding Foreground}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="itemBd" Property="Background" Value="#256366F1"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="itemBd" Property="Background" Value="#336366F1"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HistoryPriorityCheckStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="chip"
                                CornerRadius="8"
                                Padding="10,6"
                                Background="#1418273A"
                                BorderBrush="#22FFFFFF"
                                BorderThickness="1">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border x:Name="box"
                                        Width="14" Height="14"
                                        CornerRadius="4"
                                        BorderThickness="1.5"
                                        BorderBrush="#667085"
                                        Background="Transparent"
                                        Margin="0,0,7,0">
                                    <Path x:Name="check"
                                          Data="M3,7 L6,10 L11,4"
                                          Stroke="White"
                                          StrokeThickness="1.7"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Visibility="Collapsed"/>
                                </Border>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="chip" Property="Background" Value="#1F6366F1"/>
                                <Setter TargetName="chip" Property="BorderBrush" Value="#556366F1"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter TargetName="chip" Property="Background" Value="#2234D399"/>
                                <Setter TargetName="chip" Property="BorderBrush" Value="#664ADE80"/>
                                <Setter TargetName="box" Property="Background" Value="#4ADE80"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="#4ADE80"/>
                                <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HistoryComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="#1418273A"/>
            <Setter Property="BorderBrush" Value="#336366F1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource HistoryComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Padding="12,7"
                                          Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd"
                                                CornerRadius="8"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid Margin="{TemplateBinding Padding}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  TextElement.Foreground="#F8FAFC"
                                                                  VerticalAlignment="Center"/>
                                                <Path Grid.Column="1"
                                                      Data="M0,0 L4,4 L8,0"
                                                      Stroke="#9CA3AF"
                                                      StrokeThickness="1.5"
                                                      Fill="Transparent"
                                                      Width="8" Height="5"
                                                      Margin="8,0,0,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Right"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#1F6366F1"/>
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#666366F1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="#1B1B2F"
                                        BorderBrush="#666366F1"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Margin="0,4,0,0"
                                        Padding="2"
                                        MaxHeight="200">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HistoryDateFieldBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#1A6366F1"/>
            <Setter Property="BorderBrush" Value="#666366F1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#A855F7" BlurRadius="8" ShadowDepth="0" Opacity="0.35"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Path=(utils:VisualEffects.IsReducingEffects), RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True">
                    <Setter Property="Effect" Value="{x:Null}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NeonDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Grid x:Name="PART_Root">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <DatePickerTextBox x:Name="PART_TextBox"
                                               Grid.Column="0"
                                               HorizontalContentAlignment="Left"
                                               VerticalContentAlignment="Center"
                                               Background="Transparent"
                                               BorderThickness="0"
                                               Foreground="{TemplateBinding Foreground}">
                                <DatePickerTextBox.Template>
                                    <ControlTemplate TargetType="DatePickerTextBox">
                                        <ScrollViewer x:Name="PART_ContentHost" Margin="4,0"/>
                                    </ControlTemplate>
                                </DatePickerTextBox.Template>
                            </DatePickerTextBox>
                            <Button x:Name="PART_Button"
                                    Grid.Column="1"
                                    Focusable="False"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Margin="0,0,4,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent" Padding="4">
                                            <Image Source="pack://application:,,,/Assets/calendar.png" Width="16" Height="16" Opacity="0.9" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.6"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=PART_Root}"
                                   StaysOpen="False"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Style="{StaticResource SubWindowBorderStyle}">

        <Grid>
            <Grid.RowDefinitions>
                <!-- 标题栏 -->
                <RowDefinition Height="Auto"/>
                <!-- 搜索区域 -->
                <RowDefinition Height="Auto"/>
                <!-- 搜索结果列表 -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ========== 标题栏 ========== -->
            <Border Background="Transparent"
                    CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="20,14">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="24" Height="24" CornerRadius="6" Background="#336366F1">
                            <!-- 优化：使用矢量剪贴板图标替代 Emoji -->
                            <Path Data="{StaticResource IconHistory}" 
                                  Fill="{StaticResource ThemePrimaryBrush}" 
                                  Width="12" Height="12" Stretch="Uniform" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="历史任务查询" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- 右侧：窗口控制（胶囊风格） -->
                    <Border Style="{StaticResource JellyCapsuleStyle}" HorizontalAlignment="Right"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="min" Style="{StaticResource JellyWinBtn}" Click="MinimizeButton_Click"/>
                            <Button Content="max" Style="{StaticResource JellyWinBtn}" Click="MaximizeButton_Click"/>
                            <Button Content="exit" Style="{StaticResource JellyWinCloseBtn}" Click="CloseButton_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ========== 搜索区域 ========== -->
            <StackPanel Grid.Row="1" Margin="20,20,20,12">
                <!-- 日期行 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="开始日期" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Border Grid.Column="1" Margin="0,0,10,0"
                            Style="{StaticResource HistoryDateFieldBorderStyle}">
                        <DatePicker SelectedDate="{Binding StartDate}"
                                    Style="{StaticResource NeonDatePickerStyle}"
                                    Margin="4,2"/>
                    </Border>

                    <TextBlock Grid.Column="2" Text="至" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Border Grid.Column="3"
                            Style="{StaticResource HistoryDateFieldBorderStyle}">
                        <DatePicker SelectedDate="{Binding EndDate}"
                                    Style="{StaticResource NeonDatePickerStyle}"
                                    Margin="4,2"/>
                    </Border>
                </Grid>

                <!-- 关键词行 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="关键词" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0" Width="52"/>
                    <TextBox Grid.Column="1"
                             Style="{StaticResource DarkTextBox}"
                             Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,10,0" Padding="10,8" FontSize="13"/>

                    <Button Grid.Column="2"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding SearchCommand}"
                            Padding="16,8" FontSize="13" Margin="0,0,8,0">
                        <!-- 优化：放大镜矢量图标 + 文字组合 -->
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconSearch}" Fill="White" 
                                  Width="13" Height="13" Stretch="Uniform" 
                                  Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="搜索" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="3" Padding="16,8" FontSize="13" Cursor="Hand"
                            Command="{Binding ExportCsvCommand}">
                        <Button.Content>
                            <!-- 优化：导出矢量图标 + 文字组合 -->
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconExport}" Fill="#4ADE80" 
                                      Width="13" Height="13" Stretch="Uniform" 
                                      Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="导出" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#1F22C55E"/>
                                <Setter Property="Foreground" Value="#4ADE80"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="BorderBrush" Value="#3322C55E"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#3322C55E"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- 分隔线 -->
                <Border Height="1" Background="{StaticResource SeparatorBrush}" Margin="0,12,0,8"/>

                <!-- 状态筛选行 — Chip 按钮组 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="筛选" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <RadioButton Content="全部" GroupName="StatusGroup"
                                 Style="{StaticResource HistoryFilterChipStyle}"
                                 IsChecked="{Binding StatusFilter, Converter={StaticResource IntToBoolConverter}, ConverterParameter=0}"/>
                    <RadioButton Content="未完成" GroupName="StatusGroup"
                                 Style="{StaticResource HistoryFilterChipStyle}"
                                 IsChecked="{Binding StatusFilter, Converter={StaticResource IntToBoolConverter}, ConverterParameter=1}"/>
                    <RadioButton Content="已完成" GroupName="StatusGroup"
                                 Style="{StaticResource HistoryFilterChipStyle}"
                                 IsChecked="{Binding StatusFilter, Converter={StaticResource IntToBoolConverter}, ConverterParameter=2}"/>
                </StackPanel>

                <!-- 排序行 -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="排序" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>

                    <ComboBox Grid.Column="1" x:Name="SortFieldCombo"
                              Style="{StaticResource HistoryComboBoxStyle}"
                              FontSize="12"
                              SelectedValuePath="Tag"
                              SelectedValue="{Binding SortField, Mode=TwoWay}">
                        <ComboBoxItem Content="发布时间" Tag="CreatedAt" Style="{StaticResource HistoryComboBoxItemStyle}"/>
                        <ComboBoxItem Content="完成时间" Tag="CompletedAt" Style="{StaticResource HistoryComboBoxItemStyle}"/>
                        <ComboBoxItem Content="最后修改时间" Tag="LastModifiedAt" Style="{StaticResource HistoryComboBoxItemStyle}"/>
                    </ComboBox>

                    <Button Grid.Column="2"
                            Content="{Binding SortDirectionText}"
                            FontSize="12" Padding="10,6" Margin="10,0"
                            Cursor="Hand" Style="{StaticResource SecondaryButton}"
                            Click="SortDirectionBtn_Click"/>

                    <CheckBox Grid.Column="3"
                              Content="等级优先"
                              Style="{StaticResource HistoryPriorityCheckStyle}"
                              Margin="10,0,0,0"
                              Click="PriorityFirst_Changed"/>
                </Grid>

                <!-- 搜索结果计数 -->
                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,10,0,0">
                    <TextBlock.Text>
                        <Binding Path="ResultCount" StringFormat="找到 {0} 条记录"/>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>

            <!-- ========== 搜索结果列表 ========== -->
            <ListBox x:Name="HistoryResultsList"
                     Grid.Row="2"
                     Margin="20,0,20,20"
                     Background="Transparent"
                     BorderThickness="0"
                     Focusable="False"
                     ItemsSource="{Binding SearchResults}"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.CanContentScroll="True"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     VirtualizingPanel.CacheLength="1"
                     VirtualizingPanel.CacheLengthUnit="Page">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBackgroundBrush}"
                                    CornerRadius="10" Margin="0,0,0,6"
                                    BorderBrush="#0AFFFFFF" BorderThickness="1"
                                    Padding="16,14" Cursor="Hand"
                                    MouseLeftButtonDown="TaskCard_MouseLeftButtonDown">
                                <Grid Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 状态标签 -->
                                    <Border Grid.Column="0" CornerRadius="20" Padding="10,3"
                                            VerticalAlignment="Center" Margin="0,0,12,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#26F59E0B"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                        <Setter Property="Background" Value="#2622C55E"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="11" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="未完成"/>
                                                    <Setter Property="Foreground" Value="#FBBF24"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="Text" Value="已完成"/>
                                                            <Setter Property="Foreground" Value="#4ADE80"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <!-- 任务信息 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontSize="14"
                                                   FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,3,0,0">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource TaskTimeDisplayConverter}">
                                                    <Binding Path="CreatedAt" StringFormat="{}{0:yyyy-MM-dd · }"/>
                                                    <Binding Path="CompletedAt"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- 删除按钮 -->
                                    <TextBlock Grid.Column="2" Text="✕" FontSize="16"
                                               Foreground="{StaticResource DangerBrush}"
                                               Background="Transparent"
                                               VerticalAlignment="Center" Cursor="Hand"
                                               Padding="4"
                                               MouseLeftButtonDown="DeleteButton_Click"
                                               Tag="{Binding}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Opacity" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                                                        <Setter Property="Opacity" Value="0.6"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Window>
