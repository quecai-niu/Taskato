<Window x:Class="Taskato.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Taskato.Converters"
        Title="历史任务查询"
        Width="640" Height="630"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="80" 
                      ResizeBorderThickness="40" 
                      GlassFrameThickness="0" 
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    <!--
        这个窗体会以对话框模式打开（ShowDialog），
        关闭后焦点回到主窗体。
    -->
    <Window.Resources>
        <Style x:Key="NeonDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Grid x:Name="PART_Root">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <DatePickerTextBox x:Name="PART_TextBox"
                                               Grid.Column="0"
                                               HorizontalContentAlignment="Left"
                                               VerticalContentAlignment="Center"
                                               Background="Transparent"
                                               BorderThickness="0"
                                               Foreground="{TemplateBinding Foreground}">
                                <DatePickerTextBox.Template>
                                    <ControlTemplate TargetType="DatePickerTextBox">
                                        <ScrollViewer x:Name="PART_ContentHost" Margin="4,0"/>
                                    </ControlTemplate>
                                </DatePickerTextBox.Template>
                            </DatePickerTextBox>
                            <Button x:Name="PART_Button"
                                    Grid.Column="1"
                                    Focusable="False"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Margin="0,0,4,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent" Padding="4">
                                            <Image Source="pack://application:,,,/Assets/calendar.png" Width="16" Height="16" Opacity="0.9" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.6"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=PART_Root}"
                                   StaysOpen="False"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Style="{StaticResource SubWindowBorderStyle}">

        <Grid>
            <Grid.RowDefinitions>
                <!-- 标题栏 -->
                <RowDefinition Height="Auto"/>
                <!-- 搜索区域 -->
                <RowDefinition Height="Auto"/>
                <!-- 搜索结果列表 -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ========== 标题栏 ========== -->
            <Border Background="Transparent"
                    CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="20,14">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="24" Height="24" CornerRadius="6" Background="#336366F1">
                            <!-- 优化：使用矢量剪贴板图标替代 Emoji -->
                            <Path Data="{StaticResource IconHistory}" 
                                  Fill="{StaticResource ThemePrimaryBrush}" 
                                  Width="12" Height="12" Stretch="Uniform" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="历史任务查询" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- 右侧：窗口控制（胶囊风格） -->
                    <Border Style="{StaticResource JellyCapsuleStyle}" HorizontalAlignment="Right"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="min" Style="{StaticResource JellyWinBtn}" Click="MinimizeButton_Click"/>
                            <Button Content="max" Style="{StaticResource JellyWinBtn}" Click="MaximizeButton_Click"/>
                            <Button Content="exit" Style="{StaticResource JellyWinCloseBtn}" Click="CloseButton_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ========== 搜索区域 ========== -->
            <StackPanel Grid.Row="1" Margin="20,20,20,12">
                <!-- 日期行 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="开始日期" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Border Grid.Column="1" Margin="0,0,10,0"
                            Background="#1A6366F1"
                            BorderBrush="#666366F1"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Border.Effect>
                            <DropShadowEffect Color="#A855F7" BlurRadius="8" ShadowDepth="0" Opacity="0.2"/>
                        </Border.Effect>
                        <DatePicker SelectedDate="{Binding StartDate}"
                                    Style="{StaticResource NeonDatePickerStyle}"
                                    Margin="4,2"/>
                    </Border>

                    <TextBlock Grid.Column="2" Text="至" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Border Grid.Column="3"
                            Background="#1A6366F1"
                            BorderBrush="#666366F1"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Border.Effect>
                            <DropShadowEffect Color="#A855F7" BlurRadius="8" ShadowDepth="0" Opacity="0.2"/>
                        </Border.Effect>
                        <DatePicker SelectedDate="{Binding EndDate}"
                                    Style="{StaticResource NeonDatePickerStyle}"
                                    Margin="4,2"/>
                    </Border>
                </Grid>

                <!-- 关键词行 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="关键词" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0" Width="52"/>
                    <TextBox Grid.Column="1"
                             Style="{StaticResource DarkTextBox}"
                             Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,10,0" Padding="10,8" FontSize="13"/>

                    <Button Grid.Column="2"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding SearchCommand}"
                            Padding="16,8" FontSize="13" Margin="0,0,8,0">
                        <!-- 优化：放大镜矢量图标 + 文字组合 -->
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconSearch}" Fill="White" 
                                  Width="13" Height="13" Stretch="Uniform" 
                                  Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="搜索" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="3" Padding="16,8" FontSize="13" Cursor="Hand"
                            Command="{Binding ExportCsvCommand}">
                        <Button.Content>
                            <!-- 优化：导出矢量图标 + 文字组合 -->
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconExport}" Fill="#4ADE80" 
                                      Width="13" Height="13" Stretch="Uniform" 
                                      Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="导出" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#1F22C55E"/>
                                <Setter Property="Foreground" Value="#4ADE80"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="BorderBrush" Value="#3322C55E"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#3322C55E"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- 分隔线 -->
                <Border Height="1" Background="{StaticResource SeparatorBrush}" Margin="0,12,0,8"/>

                <!-- 状态筛选行 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="筛选" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <RadioButton Content="全部" GroupName="StatusGroup"
                                 Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"
                                 VerticalAlignment="Center" Margin="0,0,10,0"
                                 Click="StatusFilter_Click" Tag="0"/>
                    <RadioButton Content="未完成" GroupName="StatusGroup"
                                 Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"
                                 VerticalAlignment="Center" Margin="0,0,10,0"
                                 Click="StatusFilter_Click" Tag="1"/>
                    <RadioButton Content="已完成" GroupName="StatusGroup"
                                 Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"
                                 VerticalAlignment="Center"
                                 Click="StatusFilter_Click" Tag="2"/>
                </StackPanel>

                <!-- 排序行 -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="排序" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>

                    <ComboBox Grid.Column="1" x:Name="SortFieldCombo"
                              SelectedIndex="0" FontSize="12"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              Background="#1A6366F1" BorderBrush="#666366F1"
                              SelectionChanged="SortFieldCombo_SelectionChanged">
                        <ComboBoxItem Content="发布时间" Tag="CreatedAt"/>
                        <ComboBoxItem Content="完成时间" Tag="CompletedAt"/>
                        <ComboBoxItem Content="最后修改时间" Tag="LastModifiedAt"/>
                    </ComboBox>

                    <Button Grid.Column="2"
                            x:Name="SortDirectionBtn"
                            Content="↓ 降序" FontSize="12" Padding="10,6" Margin="10,0"
                            Cursor="Hand" Style="{StaticResource SecondaryButton}"
                            Click="SortDirectionBtn_Click"/>

                    <CheckBox Grid.Column="3"
                              Content="等级优先"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              FontSize="12" VerticalAlignment="Center"
                              Margin="10,0,0,0"
                              Click="PriorityFirst_Changed"/>
                </Grid>

                <!-- 搜索结果计数 -->
                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,10,0,0">
                    <TextBlock.Text>
                        <Binding Path="ResultCount" StringFormat="找到 {0} 条记录"/>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>

            <!-- ========== 搜索结果列表 ========== -->
            <ScrollViewer Grid.Row="2" Margin="20,0,20,20" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding SearchResults}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBackgroundBrush}"
                                    CornerRadius="10" Margin="0,0,0,6"
                                    BorderBrush="#0AFFFFFF" BorderThickness="1"
                                    Padding="16,14" Cursor="Hand"
                                    MouseLeftButtonDown="TaskCard_MouseLeftButtonDown">
                                <Grid Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 状态标签 -->
                                    <Border Grid.Column="0" CornerRadius="20" Padding="10,3"
                                            VerticalAlignment="Center" Margin="0,0,12,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#26F59E0B"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                        <Setter Property="Background" Value="#2622C55E"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="11" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="未完成"/>
                                                    <Setter Property="Foreground" Value="#FBBF24"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="Text" Value="已完成"/>
                                                            <Setter Property="Foreground" Value="#4ADE80"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <!-- 任务信息 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontSize="14"
                                                   FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,3,0,0">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource TaskTimeDisplayConverter}">
                                                    <Binding Path="CreatedAt" StringFormat="{}{0:yyyy-MM-dd · }"/>
                                                    <Binding Path="CompletedAt"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- 删除按钮 -->
                                    <TextBlock Grid.Column="2" Text="✕" FontSize="16"
                                               Foreground="{StaticResource DangerBrush}"
                                               Background="Transparent"
                                               VerticalAlignment="Center" Cursor="Hand"
                                               Padding="4"
                                               MouseLeftButtonDown="DeleteButton_Click"
                                               Tag="{Binding}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Opacity" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                                                        <Setter Property="Opacity" Value="0.6"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
