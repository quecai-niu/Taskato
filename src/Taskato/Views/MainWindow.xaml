<Window x:Class="Taskato.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Taskato.Converters"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Taskato"
        Icon="/Assets/icon.png"
        Width="480" Height="700"
        MinWidth="400" MinHeight="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen">
    <!--
        WindowStyle="None" + AllowsTransparency="True":
        隐藏系统默认标题栏，使用自定义标题栏实现 macOS 风格的三色圆点。
        Background="Transparent" 配合圆角边框实现窗体圆角效果。
    -->

    <!-- 主容器 — 圆角暗色窗体 -->
    <Border CornerRadius="16"
            Background="{StaticResource WindowBackgroundBrush}"
            BorderBrush="#266366F1" BorderThickness="1">
        <Border.Effect>
            <!-- 窗体阴影效果 -->
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="10" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <!-- 自定义标题栏 -->
                <RowDefinition Height="Auto"/>
                <!-- 输入区域 -->
                <RowDefinition Height="Auto"/>
                <!-- 日期标签 -->
                <RowDefinition Height="Auto"/>
                <!-- 任务列表（自动填满） -->
                <RowDefinition Height="*"/>
                <!-- 番茄钟区域 -->
                <RowDefinition Height="Auto"/>
                <!-- 底部功能栏 -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ========== Row 0: 自定义标题栏 ========== -->
            <Border Grid.Row="0" Background="#08FFFFFF"
                    BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,0,0,1"
                    CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="20,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：应用图标 + 名称 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <!-- 小方块图标（紫色渐变） -->
                        <Border Width="24" Height="24" CornerRadius="6"
                                Background="{DynamicResource ThemeGradientBrush}">
                            <TextBlock Text="✦" FontSize="14" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Taskato" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- 右侧：Windows 风格窗口控制按钮 (V2 深度打磨) -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="—" Style="{StaticResource CuteWinBtn}" Click="MinimizeButton_Click"/>
                        <Button Content="⬜" Style="{StaticResource CuteWinBtn}" Click="MaximizeButton_Click" FontSize="10"/>
                        <Button Content="✕" Style="{StaticResource CuteWinCloseBtn}" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ========== Row 1: 任务输入区域 (像素级精密打磨版) ========== -->
            <!-- ========== Row 1: 任务输入区域 ========== -->
            <Border Grid.Row="1"
                    Background="#0FFFFFFF"
                    BorderBrush="#1AFFFFFF"
                    BorderThickness="1"
                    CornerRadius="14"
                    Height="48"
                    Margin="20,0,20,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 输入框 + 水印叠层 -->
                    <Grid Grid.Column="0">
                        <TextBlock Text="请输入新任务，按 Enter 添加..."
                                   Foreground="#40FFFFFF" FontSize="14"
                                   VerticalAlignment="Center" Margin="16,0,0,0"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NewTaskTitle}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NewTaskTitle}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="White" CaretBrush="White"
                                 FontSize="14" VerticalContentAlignment="Center"
                                 Padding="16,0,10,0"
                                 Style="{x:Null}"
                                 KeyDown="TaskInput_KeyDown"/>
                    </Grid>

                    <!-- 优先级圆点 -->
                    <ListBox Grid.Column="1"
                             SelectedIndex="{Binding NewTaskPriority}"
                             Background="Transparent" BorderThickness="0"
                             VerticalAlignment="Center" Margin="0,0,8,0" Padding="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <!-- Margin 5,0 让圆点之间有足够间距，视觉上清晰可点击 -->
                                <Setter Property="Margin" Value="5,0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="Transparent" Padding="2">
                                                <!-- 未选中：12×12 实心圆；选中：放大到 16×16 并加白色描边表示选中 -->
                                                <Ellipse x:Name="dot" Width="12" Height="12"
                                                         Fill="{TemplateBinding Foreground}"
                                                         Stroke="Transparent" StrokeThickness="2"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="dot" Property="Stroke" Value="White"/>
                                                    <Setter TargetName="dot" Property="Width" Value="16"/>
                                                    <Setter TargetName="dot" Property="Height" Value="16"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBoxItem Foreground="{StaticResource Pri0Brush}" ToolTip="普通"/>
                        <ListBoxItem Foreground="{StaticResource Pri1Brush}" ToolTip="中"/>
                        <ListBoxItem Foreground="{StaticResource Pri2Brush}" ToolTip="高"/>
                        <ListBoxItem Foreground="{StaticResource Pri3Brush}" ToolTip="紧急"/>
                    </ListBox>

                    <!-- 添加按钮 -->
                    <Button Grid.Column="2" Content="+"
                            Command="{Binding AddTaskCommand}"
                            Width="44" Height="44" Margin="0,0,2,0"
                            Foreground="White" FontSize="22" FontWeight="Light"
                            Cursor="Hand" ToolTip="添加任务">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" CornerRadius="14"
                                        Background="{DynamicResource ThemeGradientBrush}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- ========== Row 2: 日期标签 + 统计 ========== -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="20,0,20,8">
                <TextBlock Text="📅" FontSize="12" FontFamily="Segoe UI Emoji" 
                           Foreground="{DynamicResource TextSecondaryBrush}" 
                           VerticalAlignment="Center" Opacity="0.8"/>
                <TextBlock x:Name="DateLabel" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource ThemePrimaryBrush}"
                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="完成 {0}/{1}">
                            <Binding Path="CompletedCount"/>
                            <Binding Path="TotalCount"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>

            <!-- ========== Row 3: 任务列表（可滚动） ========== -->
            <ScrollViewer Grid.Row="3" Margin="20,0" VerticalScrollBarVisibility="Auto"
                          Padding="0,0,4,0">
                <ItemsControl ItemsSource="{Binding TodayTasks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- 单个任务卡片容器
                                 ClipToBounds=True 是关键：确保内部的左侧色条被裁切成与卡片相同的圆角，
                                 这样左色条在顶角/底角处呈圆形，而不是直角突出。-->
                            <Border x:Name="taskCard"
                                    Background="{StaticResource CardBackgroundBrush}"
                                    CornerRadius="14" Margin="0,0,0,10"
                                    BorderThickness="0"
                                    Cursor="Hand" ClipToBounds="True"
                                    MouseLeftButtonDown="TaskCard_MouseLeftButtonDown">
                                <Grid>
                                    <!-- 左侧优先级色条：固定宽4px，铺满卡片全高。
                                         由于外层 Border 有 ClipToBounds=True 和 CornerRadius=14，
                                         这个色条的左上角和左下角会被自动裁切成圆角，
                                         右侧则直接与卡片内容相邻，实现"只有左侧有颜色"的效果。 -->
                                    <Border Width="4" HorizontalAlignment="Left" VerticalAlignment="Stretch">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource Pri0Brush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Priority}" Value="1">
                                                        <Setter Property="Background" Value="{StaticResource Pri1Brush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Priority}" Value="2">
                                                        <Setter Property="Background" Value="{StaticResource Pri2Brush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Priority}" Value="3">
                                                        <Setter Property="Background" Value="{StaticResource Pri3Brush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>

                                    <!-- 内容区：左边距14px（色条4px+文字间距10px） -->
                                    <Grid Margin="14,14,14,14" Background="Transparent">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 勾选框 -->
                                        <Border Grid.Column="0" Width="20" Height="20" CornerRadius="6"
                                                BorderThickness="2" Cursor="Hand"
                                                Margin="0,0,12,0"
                                                MouseLeftButtonDown="Checkbox_Click"
                                                Tag="{Binding}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="#33FFFFFF"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource ThemeGradientBrush}"/>
                                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <TextBlock Text="✓" FontSize="12" FontWeight="Bold" Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Opacity" Value="0"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                    <Setter Property="Opacity" Value="1"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>

                                        <!-- 任务文本内容 -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayTitle}" FontSize="14" FontWeight="Medium" TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <ItemsControl ItemsSource="{Binding Tags}" Margin="0,4,0,0">
                                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#26A855F7" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                                            <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#D8B4FE">
                                                                <Run Text="#" Foreground="#99D8B4FE"/><Run Text="{Binding}"/>
                                                            </TextBlock>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,3,0,0">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource TaskTimeDisplayConverter}">
                                                        <Binding Path="CreatedAt"/><Binding Path="CompletedAt"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- 右侧悬浮删除按钮 -->
                                        <TextBlock Grid.Column="2" Text="✕" FontSize="14" Foreground="{StaticResource DangerBrush}"
                                                   VerticalAlignment="Center" Cursor="Hand" Padding="8" Tag="{Binding}"
                                                   MouseLeftButtonDown="DeleteButton_Click">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Opacity" Value="0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                                                            <Setter Property="Opacity" Value="0.6"/>
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="1"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- ========== Row 4: 番茄钟区域 ========== -->
            <!-- 番茄钟区域：Margin/Padding 收紧，避免挤压上方任务列表 -->
            <Border Grid.Row="4" Margin="20,6" Padding="14,10"
                    CornerRadius="14" BorderThickness="1"
                    BorderBrush="#1F6366F1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#146366F1" Offset="0"/>
                        <GradientStop Color="#0FA855F7" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <StackPanel>
                    <!-- 标题行: 番茄钟图标(果冻底座) + 状态标签 -->
                    <Grid Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <!-- 番茄钟标识：通过颜色和符号快速识别功能区域 -->
                            <!-- 番茄钟图标：精调深红“果冻”风格
                                 背景 #1FCD1A1A 为深红色的 12% 透明版本，确保底座有色且轻盈比较通透
                                 Foreground #CD1A1A 为更正宗的番茄深红色
                                 Padding="0,0,0,2" 强制微调 Emoji 重心，解决视觉偏低的问题 -->
                            <Border Width="26" Height="26" CornerRadius="8"
                                    Background="#1FCD1A1A" VerticalAlignment="Center">
                                <TextBlock Text="🍅" FontSize="14" Foreground="#FF4D4D"
                                           FontFamily="Segoe UI Emoji"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Padding="0,0,0,2"/>
                            </Border>
                            <TextBlock Text=" 番茄钟" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#A78BFA" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- 状态标签：精调文字对齐，解决视觉偏高的问题 -->
                        <Border HorizontalAlignment="Right" VerticalAlignment="Center" 
                                CornerRadius="20" Background="#266366F1" Padding="10,3">
                            <TextBlock Text="{Binding PomodoroStatusText}"
                                       FontSize="11" FontWeight="Medium" Foreground="#A78BFA"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <!-- 计时器显示 (含时间微调) -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                        <Button Content="－" Command="{Binding DecreaseTimeCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource JellyIconBtn}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTimerRunning}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <!-- 计时器数字：增加左右边距（从 12 拉大到 24）以缓解拥挤感 -->
                        <TextBlock Text="{Binding TimerDisplay}" FontSize="40" FontWeight="Bold" Foreground="White" Margin="24,0"/>
                        <Button Content="＋" Command="{Binding IncreaseTimeCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource JellyIconBtn}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTimerRunning}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- 进度条 -->
                    <ProgressBar Height="4" Margin="0,0,0,10"
                                 Minimum="0" Maximum="1"
                                 Value="{Binding TimerProgress, Mode=OneWay}"
                                 BorderThickness="0">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Setter Property="Background" Value="#14FFFFFF"/>
                                <Setter Property="Foreground">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#6366F1" Offset="0"/>
                                            <GradientStop Color="#A855F7" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ProgressBar">
                                            <Grid>
                                                <Border Background="{TemplateBinding Background}" CornerRadius="2"/>
                                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="2">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#6366F1" Offset="0"/>
                                                            <GradientStop Color="#A855F7" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>

                    <!-- 控制按钮组：横排三个按钮。
                         第三个按钮在空闲/暂停时显示"⏹ 停止"（红色），用 DangerButton 样式；
                         工作倒计时中（IsWorkingState=True）时，通过 DataTrigger 自动切换
                         Content 为"☕ 提前休息"、Command 为 EarlyRestCommand，
                         点击即直接跳入休息倒计时，无需额外显隐第四个按钮。 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <!-- 开始按钮：倒计时开始后变为“🚀 运行中”并呈半透明禁用态 -->
                        <Button Margin="0,0,8,0" Padding="20,9"
                                Command="{Binding StartPomodoroCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                    <Setter Property="Content" Value="▶ 开始"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTimerRunning}" Value="True">
                                            <Setter Property="Content" Value="🚀 运行中"/>
                                            <Setter Property="Opacity" Value="0.6"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- 暂停/继续按钮：暂停时变为“▶ 继续”并切换为高亮的主要按钮样式 -->
                        <Button Margin="0,0,8,0" Padding="20,9"
                                Command="{Binding PausePomodoroCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Setter Property="Content" Value="⏸ 暂停"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                            <!-- 暂停时切换为 PrimaryButton 的渐变底纹和文字内容 -->
                                            <Setter Property="Content" Value="▶ 继续"/>
                                            <Setter Property="Background" Value="{DynamicResource ThemeGradientBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsTimerRunning}" Value="False">
                                            <!-- 未运行状态下禁用暂停按钮 -->
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <!-- 停止/提前休息 二合一按钮 -->
                        <Button Padding="20,9">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                    <!-- 默认状态：停止，执行 StopPomodoroCommand -->
                                    <Setter Property="Content" Value="⏹ 停止"/>
                                    <Setter Property="Command" Value="{Binding StopPomodoroCommand}"/>
                                    <Style.Triggers>
                                        <!-- 工作倒计时中：切换为提前休息，执行 EarlyRestCommand -->
                                        <DataTrigger Binding="{Binding IsWorkingState}" Value="True">
                                            <Setter Property="Content" Value="☕ 提前休息"/>
                                            <Setter Property="Command" Value="{Binding EarlyRestCommand}"/>
                                        </DataTrigger>
                                        <!-- 休息倒计时中：切换为结束休息 -->
                                        <DataTrigger Binding="{Binding IsRestingState}" Value="True">
                                            <Setter Property="Content" Value="⏹ 结束休息"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ========== Row 5: 底部功能栏 ========== -->
            <Border Grid.Row="5" BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,16,16">
                <Grid Margin="20,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Style="{StaticResource SecondaryButton}"
                            Content="📋 历史记录"
                            Command="{Binding OpenHistoryCommand}"
                            HorizontalAlignment="Left"/>

                    <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                            Content="⚙ 设置 / 主题"
                            Command="{Binding OpenSettingsCommand}"
                            HorizontalAlignment="Right"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
