<Window x:Class="Taskato.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Taskato.Converters"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Taskato"
        Icon="/Assets/icon.png"
        Width="480" Height="700"
        MinWidth="400" MinHeight="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen">
    <!--
        WindowStyle="None" + AllowsTransparency="True":
        隐藏系统默认标题栏，使用自定义标题栏实现 macOS 风格的三色圆点。
        Background="Transparent" 配合圆角边框实现窗体圆角效果。
    -->

    <!-- 主容器 — 圆角暗色窗体 -->
    <Border CornerRadius="16"
            Background="{StaticResource WindowBackgroundBrush}"
            BorderBrush="#266366F1" BorderThickness="1">
        <Border.Effect>
            <!-- 窗体阴影效果 -->
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="10" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <!-- 自定义标题栏 -->
                <RowDefinition Height="Auto"/>
                <!-- 输入区域 -->
                <RowDefinition Height="Auto"/>
                <!-- 日期标签 -->
                <RowDefinition Height="Auto"/>
                <!-- 任务列表（自动填满） -->
                <RowDefinition Height="*"/>
                <!-- 番茄钟区域 -->
                <RowDefinition Height="Auto"/>
                <!-- 底部功能栏 -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ========== Row 0: 自定义标题栏 ========== -->
            <Border Grid.Row="0" Background="#08FFFFFF"
                    BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,0,0,1"
                    CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="20,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：应用图标 + 名称 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <!-- 小方块图标（紫色渐变） -->
                        <Border Width="24" Height="24" CornerRadius="6"
                                Background="{DynamicResource ThemeGradientBrush}">
                            <TextBlock Text="✦" FontSize="14" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Taskato" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- 右侧：macOS 风格窗口控制按钮 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- 最小化（黄色） -->
                        <Ellipse Width="14" Height="14" Fill="#F59E0B" Cursor="Hand"
                                 MouseLeftButtonDown="MinimizeButton_Click" Margin="0,0,8,0"/>
                        <!-- 最大化/还原（绿色） -->
                        <Ellipse Width="14" Height="14" Fill="#22C55E" Cursor="Hand"
                                 MouseLeftButtonDown="MaximizeButton_Click" Margin="0,0,8,0"/>
                        <!-- 关闭/隐藏到托盘（红色） -->
                        <Ellipse Width="14" Height="14" Fill="#EF4444" Cursor="Hand"
                                 MouseLeftButtonDown="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ========== Row 1: 任务输入区域 ========== -->
            <Grid Grid.Row="1" Margin="20,20,20,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 任务输入框 -->
                <TextBox Grid.Column="0"
                         Style="{StaticResource DarkTextBox}"
                         Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}"
                         Tag="输入新任务，按 Enter 添加..."
                         KeyDown="TaskInput_KeyDown"
                         Margin="0,0,10,0"/>

                <!-- 添加按钮 -->
                <Button Grid.Column="1"
                        Style="{StaticResource PrimaryButton}"
                        Content="+ 添加"
                        Command="{Binding AddTaskCommand}"/>
            </Grid>

            <!-- ========== Row 2: 日期标签 + 统计 ========== -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="20,0,20,8">
                <TextBlock Text="📅" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock x:Name="DateLabel" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource ThemePrimaryBrush}"
                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="完成 {0}/{1}">
                            <Binding Path="CompletedCount"/>
                            <Binding Path="TotalCount"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>

            <!-- ========== Row 3: 任务列表（可滚动） ========== -->
            <ScrollViewer Grid.Row="3" Margin="20,0" VerticalScrollBarVisibility="Auto"
                          Padding="0,0,4,0">
                <ItemsControl ItemsSource="{Binding TodayTasks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- 单个任务卡片 -->
                            <Border x:Name="taskCard"
                                    Background="{StaticResource CardBackgroundBrush}"
                                    CornerRadius="10" Margin="0,0,0,6"
                                    BorderBrush="#0AFFFFFF" BorderThickness="1"
                                    Padding="16,14" Cursor="Hand"
                                    MouseLeftButtonDown="TaskCard_MouseLeftButtonDown">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 勾选框 -->
                                    <Border Grid.Column="0" Width="20" Height="20" CornerRadius="6"
                                            BorderThickness="2" Cursor="Hand"
                                            Margin="0,0,12,0"
                                            MouseLeftButtonDown="Checkbox_Click"
                                            Tag="{Binding}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="#33FFFFFF"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource ThemeGradientBrush}"/>
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="✓" FontSize="12" FontWeight="Bold" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Opacity" Value="0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="Opacity" Value="1"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <!-- 任务内容 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <!-- 任务标题 -->
                                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Medium">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- 时间信息 -->
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,3,0,0">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource TaskTimeDisplayConverter}">
                                                    <Binding Path="CreatedAt"/>
                                                    <Binding Path="CompletedAt"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>

                                    <TextBlock Grid.Column="2" Text="✕" FontSize="16"
                                               Foreground="{StaticResource DangerBrush}"
                                               Background="Transparent"
                                               VerticalAlignment="Center" Cursor="Hand"
                                               Padding="4"
                                               MouseLeftButtonDown="DeleteButton_Click"
                                               Tag="{Binding}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Opacity" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                                                        <Setter Property="Opacity" Value="0.6"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- ========== Row 4: 番茄钟区域 ========== -->
            <Border Grid.Row="4" Margin="20,12" Padding="20"
                    CornerRadius="14" BorderThickness="1"
                    BorderBrush="#1F6366F1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#146366F1" Offset="0"/>
                        <GradientStop Color="#0FA855F7" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <StackPanel>
                    <!-- 标题行: 番茄钟 + 状态标签 -->
                    <Grid Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🍅" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text=" 番茄钟" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#A78BFA" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border HorizontalAlignment="Right" CornerRadius="20"
                                Background="#266366F1" Padding="10,4">
                            <TextBlock Text="{Binding PomodoroStatusText}"
                                       FontSize="11" FontWeight="Medium" Foreground="#A78BFA"/>
                        </Border>
                    </Grid>

                    <!-- 计时器显示 -->
                    <TextBlock Text="{Binding TimerDisplay}"
                               FontSize="48" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,12"
                               FontFamily="Consolas, Microsoft YaHei"/>

                    <!-- 进度条 -->
                    <ProgressBar Height="4" Margin="0,0,0,16"
                                 Minimum="0" Maximum="1"
                                 Value="{Binding TimerProgress, Mode=OneWay}"
                                 BorderThickness="0">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Setter Property="Background" Value="#14FFFFFF"/>
                                <Setter Property="Foreground">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#6366F1" Offset="0"/>
                                            <GradientStop Color="#A855F7" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ProgressBar">
                                            <Grid>
                                                <Border Background="{TemplateBinding Background}" CornerRadius="2"/>
                                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="2">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#6366F1" Offset="0"/>
                                                            <GradientStop Color="#A855F7" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>

                    <!-- 控制按钮组 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Style="{StaticResource PrimaryButton}" Content="▶ 开始"
                                Command="{Binding StartPomodoroCommand}" Margin="0,0,10,0"
                                Padding="24,10"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="⏸ 暂停"
                                Command="{Binding PausePomodoroCommand}" Margin="0,0,10,0"
                                Padding="24,10"/>
                        <Button Style="{StaticResource DangerButton}" Content="⏹ 停止"
                                Command="{Binding StopPomodoroCommand}"
                                Padding="24,10"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ========== Row 5: 底部功能栏 ========== -->
            <Border Grid.Row="5" BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,16,16">
                <Grid Margin="20,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Style="{StaticResource SecondaryButton}"
                            Content="📋 历史记录"
                            Command="{Binding OpenHistoryCommand}"
                            HorizontalAlignment="Left"/>

                    <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                            Content="⚙ 设置 / 主题"
                            Command="{Binding OpenSettingsCommand}"
                            HorizontalAlignment="Right"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
