<Window x:Class="Taskato.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Taskato.Converters"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Taskato"
        Icon="/Assets/icon.png"
        Width="480" Height="700"
        MinWidth="400" MinHeight="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen">
    <!--
        WindowStyle="None" + AllowsTransparency="True":
        隐藏系统默认标题栏，使用自定义标题栏实现 macOS 风格的三色圆点。
        Background="Transparent" 配合圆角边框实现窗体圆角效果。
    -->

    <!-- 主容器 — 圆角暗色窗体 -->
    <Border CornerRadius="16"
            Background="{StaticResource WindowBackgroundBrush}"
            BorderBrush="#266366F1" BorderThickness="1">
        <Border.Effect>
            <!-- 窗体阴影效果 -->
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="10" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <!-- 自定义标题栏 -->
                <RowDefinition Height="Auto"/>
                <!-- 输入区域 -->
                <RowDefinition Height="Auto"/>
                <!-- 日期标签 -->
                <RowDefinition Height="Auto"/>
                <!-- 任务列表（自动填满） -->
                <RowDefinition Height="*"/>
                <!-- 番茄钟区域 -->
                <RowDefinition Height="Auto"/>
                <!-- 底部功能栏 -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ========== Row 0: 自定义标题栏 ========== -->
            <Border Grid.Row="0" Background="#08FFFFFF"
                    BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,0,0,1"
                    CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="20,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：应用图标 + 名称 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <!-- 小方块图标（紫色渐变） -->
                        <Border Width="24" Height="24" CornerRadius="6"
                                Background="{DynamicResource ThemeGradientBrush}">
                            <TextBlock Text="✦" FontSize="14" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Taskato" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- 右侧：macOS 风格窗口控制按钮 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- 最小化（黄色） -->
                        <Ellipse Width="14" Height="14" Fill="#F59E0B" Cursor="Hand"
                                 MouseLeftButtonDown="MinimizeButton_Click" Margin="0,0,8,0"/>
                        <!-- 最大化/还原（绿色） -->
                        <Ellipse Width="14" Height="14" Fill="#22C55E" Cursor="Hand"
                                 MouseLeftButtonDown="MaximizeButton_Click" Margin="0,0,8,0"/>
                        <!-- 关闭/隐藏到托盘（红色） -->
                        <Ellipse Width="14" Height="14" Fill="#EF4444" Cursor="Hand"
                                 MouseLeftButtonDown="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ========== Row 1: 任务输入区域 (像素级精密打磨版) ========== -->
            <Border Grid.Row="1" 
                    Background="#0FFFFFFF" 
                    BorderBrush="#1AFFFFFF" 
                    BorderThickness="1" 
                    CornerRadius="12" 
                    Height="44" 
                    Margin="20,0,20,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" 
                             Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent" 
                             BorderThickness="0" 
                             Foreground="White" 
                             CaretBrush="White"
                             FontSize="14" 
                             VerticalContentAlignment="Center"
                             Padding="16,0,10,0" 
                             Style="{x:Null}" 
                             KeyDown="TaskInput_KeyDown"/>

                    <ListBox Grid.Column="1" 
                             SelectedIndex="{Binding NewTaskPriority}" 
                             Background="Transparent" 
                             BorderThickness="0" 
                             VerticalAlignment="Center"
                             Margin="0,0,12,0" 
                             Padding="0" 
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="5,0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="Transparent">
                                                <Ellipse x:Name="dot" Width="12" Height="12" 
                                                         Fill="{TemplateBinding Foreground}" 
                                                         Stroke="Transparent" StrokeThickness="2"
                                                         VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="dot" Property="Stroke" Value="White"/>
                                                    <Setter TargetName="dot" Property="Width" Value="16"/>
                                                    <Setter TargetName="dot" Property="Height" Value="16"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="dot" Property="Opacity" Value="0.8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        
                        <ListBoxItem Foreground="{StaticResource Pri0Brush}" ToolTip="普通任务"/>
                        <ListBoxItem Foreground="{StaticResource Pri1Brush}" ToolTip="中优先级"/>
                        <ListBoxItem Foreground="{StaticResource Pri2Brush}" ToolTip="高优先级"/>
                        <ListBoxItem Foreground="{StaticResource Pri3Brush}" ToolTip="紧急任务"/>
                    </ListBox>
                </Grid>
            </Border>

            <!-- ========== Row 2: 日期标签 + 统计 ========== -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="20,0,20,8">
                <TextBlock Text="📅" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock x:Name="DateLabel" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource ThemePrimaryBrush}"
                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="完成 {0}/{1}">
                            <Binding Path="CompletedCount"/>
                            <Binding Path="TotalCount"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>

            <!-- ========== Row 3: 任务列表（可滚动） ========== -->
            <ScrollViewer Grid.Row="3" Margin="20,0" VerticalScrollBarVisibility="Auto"
                          Padding="0,0,4,0">
                <ItemsControl ItemsSource="{Binding TodayTasks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- 单个任务卡片容器 -->
                            <Grid Margin="0,0,0,6">
                                <!-- 后方的隐藏删除槽（红色） -->
                                <Border Background="#EF4444" CornerRadius="10" Padding="16,14" 
                                        HorizontalAlignment="Right" Width="70"
                                        Cursor="Hand" MouseLeftButtonDown="DeleteButton_Click" Tag="{Binding}">
                                    <TextBlock Text="删除" Foreground="White" FontWeight="Bold" FontSize="13"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>

                                <!-- 任务主体卡片（支持滑动） -->
                                <Border x:Name="taskCard"
                                        Background="{StaticResource CardBackgroundBrush}"
                                        CornerRadius="14" Margin="0,0,0,12"
                                        BorderBrush="#0AFFFFFF" BorderThickness="1"
                                        Cursor="Hand" ClipToBounds="True"
                                        MouseLeftButtonDown="TaskCard_MouseLeftButtonDown"
                                        MouseMove="TaskCard_MouseMove"
                                        MouseLeftButtonUp="TaskCard_MouseLeftButtonUp"
                                        MouseLeave="TaskCard_MouseLeave">
                                    <Border.RenderTransform>
                                        <TranslateTransform X="0" />
                                    </Border.RenderTransform>
                                    <Grid>
                                        <Rectangle HorizontalAlignment="Left" Width="4">
                                            <Rectangle.Style>
                                                <Style TargetType="Rectangle">
                                                    <Setter Property="Fill" Value="{StaticResource Pri0Brush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Priority}" Value="1">
                                                            <Setter Property="Fill" Value="{StaticResource Pri1Brush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Priority}" Value="2">
                                                            <Setter Property="Fill" Value="{StaticResource Pri2Brush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Priority}" Value="3">
                                                            <Setter Property="Fill" Value="{StaticResource Pri3Brush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Rectangle.Style>
                                        </Rectangle>
                                        <Grid Background="Transparent" Margin="18,16,16,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                    <!-- 勾选框 -->
                                    <Border Grid.Column="0" Width="20" Height="20" CornerRadius="6"
                                            BorderThickness="2" Cursor="Hand"
                                            Margin="0,0,12,0"
                                            MouseLeftButtonDown="Checkbox_Click"
                                            Tag="{Binding}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="#33FFFFFF"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource ThemeGradientBrush}"/>
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <TextBlock Text="✓" FontSize="12" FontWeight="Bold" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Opacity" Value="0"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="Opacity" Value="1"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>

                                    <!-- 任务内容 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <!-- 任务标题 -->
                                        <TextBlock Text="{Binding DisplayTitle}" FontSize="14" FontWeight="Medium" TextTrimming="CharacterEllipsis">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- #标签展示 -->
                                        <ItemsControl ItemsSource="{Binding Tags}" Margin="0,4,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#26A855F7" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                                        <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#D8B4FE">
                                                            <Run Text="#" Foreground="#99D8B4FE"/>
                                                            <Run Text="{Binding}"/>
                                                        </TextBlock>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <!-- 时间信息 -->
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,3,0,0">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource TaskTimeDisplayConverter}">
                                                    <Binding Path="CreatedAt"/>
                                                    <Binding Path="CompletedAt"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- ========== Row 4: 番茄钟区域 ========== -->
            <Border Grid.Row="4" Margin="20,12" Padding="20"
                    CornerRadius="14" BorderThickness="1"
                    BorderBrush="#1F6366F1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#146366F1" Offset="0"/>
                        <GradientStop Color="#0FA855F7" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <StackPanel>
                    <!-- 标题行: 番茄钟 + 状态标签 -->
                    <Grid Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🍅" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text=" 番茄钟" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#A78BFA" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border HorizontalAlignment="Right" CornerRadius="20"
                                Background="#266366F1" Padding="10,4">
                            <TextBlock Text="{Binding PomodoroStatusText}"
                                       FontSize="11" FontWeight="Medium" Foreground="#A78BFA"/>
                        </Border>
                    </Grid>

                    <!-- 计时器显示 -->
                    <TextBlock Text="{Binding TimerDisplay}"
                               FontSize="48" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,12"
                               FontFamily="Consolas, Microsoft YaHei"/>

                    <!-- 进度条 -->
                    <ProgressBar Height="4" Margin="0,0,0,16"
                                 Minimum="0" Maximum="1"
                                 Value="{Binding TimerProgress, Mode=OneWay}"
                                 BorderThickness="0">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Setter Property="Background" Value="#14FFFFFF"/>
                                <Setter Property="Foreground">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#6366F1" Offset="0"/>
                                            <GradientStop Color="#A855F7" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ProgressBar">
                                            <Grid>
                                                <Border Background="{TemplateBinding Background}" CornerRadius="2"/>
                                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="2">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#6366F1" Offset="0"/>
                                                            <GradientStop Color="#A855F7" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>

                    <!-- 控制按钮组 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Style="{StaticResource PrimaryButton}" Content="▶ 开始"
                                Command="{Binding StartPomodoroCommand}" Margin="0,0,10,0"
                                Padding="24,10"/>
                        <Button Style="{StaticResource SecondaryButton}" Content="⏸ 暂停"
                                Command="{Binding PausePomodoroCommand}" Margin="0,0,10,0"
                                Padding="24,10"/>
                        <Button Style="{StaticResource DangerButton}" Content="⏹ 停止"
                                Command="{Binding StopPomodoroCommand}"
                                Padding="24,10"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ========== Row 5: 底部功能栏 ========== -->
            <Border Grid.Row="5" BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,16,16">
                <Grid Margin="20,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Style="{StaticResource SecondaryButton}"
                            Content="📋 历史记录"
                            Command="{Binding OpenHistoryCommand}"
                            HorizontalAlignment="Left"/>

                    <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                            Content="⚙ 设置 / 主题"
                            Command="{Binding OpenSettingsCommand}"
                            HorizontalAlignment="Right"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
