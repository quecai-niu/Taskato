<Window x:Class="Taskato.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Taskato.Converters"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:utils="clr-namespace:Taskato.Utils"
        Title="Taskato"
        Icon="/Assets/icon.png"
        Width="560" Height="780"
        MinWidth="480" MinHeight="580"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="80" 
                      ResizeBorderThickness="40" 
                      GlassFrameThickness="0" 
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    <!--
        WindowStyle="None" + AllowsTransparency="True":
        隐藏系统默认标题栏，使用自定义标题栏实现 macOS 风格的三色圆点。
        Background="Transparent" 配合圆角边框实现窗体圆角效果。
    -->

    <!-- 主容器 — 圆角暗色窗体 -->
    <Border Style="{StaticResource MainWindowBorderStyle}">

        <Grid>
            <Grid.RowDefinitions>
                <!-- 自定义标题栏 -->
                <RowDefinition Height="Auto"/>
                <!-- 输入区域 -->
                <RowDefinition Height="Auto"/>
                <!-- 日期标签 -->
                <RowDefinition Height="Auto"/>
                <!-- 任务列表（自动填满） -->
                <RowDefinition Height="*"/>
                <!-- 番茄钟区域 -->
                <RowDefinition Height="Auto"/>
                <!-- 底部功能栏 -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ========== Row 0: 自定义标题栏 ========== -->
            <Border Background="Transparent"
                    CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="20,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：应用图标 + 名称 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <!-- 小方块图标（紫色渐变） -->
                        <Border Width="24" Height="24" CornerRadius="6"
                                Background="{DynamicResource ThemeGradientBrush}">
                            <TextBlock Text="✦" FontSize="14" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Taskato" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- 右侧：Q弹果冻胶囊窗口控制 (方案 4) -->
                    <Border Grid.Column="2" Style="{StaticResource JellyCapsuleStyle}"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="min" Style="{StaticResource JellyWinBtn}" Click="MinimizeButton_Click"/>
                            <Button Content="max" Style="{StaticResource JellyWinBtn}" Click="MaximizeButton_Click"/>
                            <Button Content="exit" Style="{StaticResource JellyWinCloseBtn}" Click="CloseButton_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ========== Row 1: 任务输入区域 (方案 1: 极简流体胶囊) ========== -->
            <Border Grid.Row="1" Style="{StaticResource TaskInputCapsuleStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 输入框 + 水印叠层 -->
                    <Grid Grid.Column="0">
                        <TextBlock Text="想要完成什么？"
                                   Foreground="#40FFFFFF" FontSize="14"
                                   VerticalAlignment="Center" Margin="24,0,0,0"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NewTaskTitle}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NewTaskTitle}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox x:Name="TaskInput"
                                 Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="White" CaretBrush="White"
                                 FontSize="15" VerticalContentAlignment="Center"
                                 Padding="24,0,10,0"
                                 Style="{x:Null}"
                                 KeyDown="TaskInput_KeyDown"/>
                    </Grid>

                    <!-- 优先级圆点 (极简风格) -->
                    <ListBox Grid.Column="1"
                             SelectedIndex="{Binding NewTaskPriority}"
                             Style="{StaticResource PriorityDotListBoxStyle}"
                             ItemContainerStyle="{StaticResource PriorityDotItemStyle}"
                             Margin="0,0,14,0">
                        <ListBoxItem Foreground="{StaticResource Pri0Brush}" ToolTip="普通"/>
                        <ListBoxItem Foreground="{StaticResource Pri1Brush}" ToolTip="中"/>
                        <ListBoxItem Foreground="{StaticResource Pri2Brush}" ToolTip="高"/>
                        <ListBoxItem Foreground="{StaticResource Pri3Brush}" ToolTip="紧急"/>
                    </ListBox>

                    <!-- 圆形霓虹添加按钮 -->
                    <Button Grid.Column="2" 
                            Style="{StaticResource AddRoundButtonStyle}"
                            Command="{Binding AddTaskCommand}"
                            Margin="0,0,7,0"/>
                </Grid>
            </Border>

            <!-- ========== Row 2: 日期标签 + 统计 ========== -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="20,0,20,8">
                <TextBlock Text="📅" FontSize="12" FontFamily="Segoe UI Emoji" 
                           Foreground="{DynamicResource TextSecondaryBrush}" 
                           VerticalAlignment="Center" Opacity="0.8"/>
                <TextBlock x:Name="DateLabel" Text="{Binding DateLabelText}" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource ThemePrimaryBrush}"
                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="完成 {0}/{1}">
                            <Binding Path="CompletedCount"/>
                            <Binding Path="TotalCount"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>

            <!-- ========== Row 3: 任务列表（可滚动） ========== -->
            <ListBox x:Name="TaskList"
                     Grid.Row="3"
                     Margin="20,0"
                     Background="Transparent"
                     BorderThickness="0"
                     Focusable="False"
                     ItemsSource="{Binding TodayTasks}"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.CanContentScroll="True"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     VirtualizingPanel.CacheLength="1"
                     VirtualizingPanel.CacheLengthUnit="Page">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!-- 单个任务卡片容器 -->
                            <Border x:Name="taskCard"
                                    Background="{StaticResource CardBackgroundBrush}"
                                    CornerRadius="14" Margin="0,0,0,10"
                                    BorderThickness="0"
                                    Cursor="Hand" ClipToBounds="False"
                                    MouseLeftButtonDown="TaskCard_MouseLeftButtonDown">
                                <Grid>
                                    <!-- 左侧优先级色条 -->
                                     <Rectangle Width="4" RadiusX="2" RadiusY="2" Margin="14,14,0,14" 
                                                HorizontalAlignment="Left" VerticalAlignment="Stretch">
                                         <Rectangle.Style>
                                             <Style TargetType="Rectangle">
                                                 <Setter Property="Fill" Value="{StaticResource Pri0Brush}"/>
                                                 <Setter Property="Effect">
                                                     <Setter.Value>
                                                         <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.3"
                                                                           Color="{Binding Path=Fill.Color, RelativeSource={RelativeSource Self}}"/>
                                                     </Setter.Value>
                                                 </Setter>
                                                 <Style.Triggers>
                                                     <DataTrigger Binding="{Binding Priority}" Value="1">
                                                         <Setter Property="Fill" Value="{StaticResource Pri1Brush}"/>
                                                     </DataTrigger>
                                                     <DataTrigger Binding="{Binding Priority}" Value="2">
                                                         <Setter Property="Fill" Value="{StaticResource Pri2Brush}"/>
                                                     </DataTrigger>
                                                     <DataTrigger Binding="{Binding Priority}" Value="3">
                                                         <Setter Property="Fill" Value="{StaticResource Pri3Brush}"/>
                                                     </DataTrigger>
                                                     <DataTrigger Binding="{Binding Path=(utils:VisualEffects.IsReducingEffects), RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True">
                                                         <Setter Property="Effect" Value="{x:Null}"/>
                                                     </DataTrigger>
                                                 </Style.Triggers>
                                             </Style>
                                         </Rectangle.Style>
                                     </Rectangle>

                                    <!-- 内容区：左边距26px（色条间距） -->
                                    <Grid Margin="26,14,14,14" Background="Transparent">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 勾选框 -->
                                        <Border Grid.Column="0" Width="20" Height="20" CornerRadius="6"
                                                BorderThickness="2" Cursor="Hand"
                                                Margin="0,0,12,0"
                                                MouseLeftButtonDown="Checkbox_Click"
                                                Tag="{Binding}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="#33FFFFFF"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource ThemeGradientBrush}"/>
                                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <TextBlock Text="✓" FontSize="12" FontWeight="Bold" Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Opacity" Value="0"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                    <Setter Property="Opacity" Value="1"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>

                                        <!-- 任务文本内容 -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayTitle}" FontSize="14" FontWeight="Medium" TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <ItemsControl ItemsSource="{Binding Tags}" Margin="0,4,0,0">
                                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#26A855F7" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                                            <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#D8B4FE">
                                                                <Run Text="#" Foreground="#99D8B4FE"/><Run Text="{Binding}"/>
                                                            </TextBlock>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,3,0,0">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource TaskTimeDisplayConverter}">
                                                        <Binding Path="CreatedAt"/>
                                                        <Binding Path="CompletedAt"/>
                                                        <Binding Path="CompletionDurationMinutes"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- 右侧悬浮删除按钮 -->
                                        <TextBlock Grid.Column="2" Text="✕" FontSize="14" Foreground="{StaticResource DangerBrush}"
                                                   VerticalAlignment="Center" Cursor="Hand" Padding="8" Tag="{Binding}"
                                                   MouseLeftButtonDown="DeleteButton_Click">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Opacity" Value="0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                                                            <Setter Property="Opacity" Value="0.6"/>
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="1"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- ========== Row 4: 番茄钟区域 ========== -->
            <Border Grid.Row="4" Margin="20,6" Padding="14,10"
                    CornerRadius="14" BorderThickness="1"
                    BorderBrush="#1F6366F1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#146366F1" Offset="0"/>
                        <GradientStop Color="#0FA855F7" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <StackPanel>
                    <Border DataContext="{Binding CurrentActiveTimer}">
                        <StackPanel>
                            <!-- 标题行: 番茄钟图标(果冻底座) + 状态标签 -->
                    <Grid Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="26" Height="26" CornerRadius="8"
                                    Background="#1FCD1A1A" VerticalAlignment="Center">
                                <Image Source="pack://application:,,,/Assets/pomodoro_icon.png" Width="20" Height="20" 
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text=" 番茄钟" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#A78BFA" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- 状态标签：方案 2 霓虹辉光 (ContentControl 实现) -->
                        <ContentControl HorizontalAlignment="Right" Style="{StaticResource PomodoroStatusTagStyle}">
                            <TextBlock Text="{Binding StatusText}"
                                       FontSize="11.5" FontWeight="Bold" Foreground="White"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       TextOptions.TextRenderingMode="ClearType"
                                       TextOptions.TextFormattingMode="Display"/>
                        </ContentControl>
                    </Grid>

                    <!-- 计时器显示 (含时间微调) -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                        <Button Content="－" Command="{Binding DecreaseTimeCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource JellyIconBtn}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStarted}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <TextBlock Text="{Binding TimerDisplay}" FontSize="40" FontWeight="Bold" Foreground="White" Margin="24,0"/>
                        <Button Content="＋" Command="{Binding IncreaseTimeCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource JellyIconBtn}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStarted}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- 进度条 -->
                    <ProgressBar Height="4" Margin="0,0,0,10"
                                 Minimum="0" Maximum="1"
                                 Value="{Binding Progress, Mode=OneWay}"
                                 BorderThickness="0">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Setter Property="Background" Value="#14FFFFFF"/>
                                <Setter Property="Foreground">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#6366F1" Offset="0"/>
                                            <GradientStop Color="#A855F7" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ProgressBar">
                                            <Grid>
                                                <Border Background="{TemplateBinding Background}" CornerRadius="2"/>
                                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="2">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#6366F1" Offset="0"/>
                                                            <GradientStop Color="#A855F7" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>

                    <!-- 控制按钮组 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Margin="0,0,8,0" Padding="20,9" Command="{Binding StartWorkCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                    <Setter Property="Content" Value="▶ 开始"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStarted}" Value="True">
                                            <Setter Property="Content" Value="🚀 运行中"/>
                                            <Setter Property="Opacity" Value="0.6"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Margin="0,0,8,0" Padding="20,9" Command="{Binding PauseCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Setter Property="Content" Value="⏸ 暂停"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                            <Setter Property="Content" Value="▶ 继续"/>
                                            <Setter Property="Background" Value="{DynamicResource ThemeGradientBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsStarted}" Value="False">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Padding="20,9">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                    <Setter Property="Content" Value="⏹ 停止"/>
                                    <Setter Property="Command" Value="{Binding StopCommand}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsWorkingState}" Value="True">
                                            <Setter Property="Content" Value="☕ 提前休息"/>
                                            <Setter Property="Command" Value="{Binding EarlyRestCommand}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsRestingState}" Value="True">
                                            <Setter Property="Content" Value="⏹ 结束休息"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 附加计时器区域 (多组模式) -->
                    <Border Visibility="{Binding IsMultiMode, Converter={StaticResource BoolToVisibilityConverter}}"
                            Margin="0,24,0,0">
                        <StackPanel>
                            <!-- 选项卡与添加按钮 -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" Padding="0,0,8,0">
                                    <ListBox ItemsSource="{Binding AllTimers}" 
                                             SelectedItem="{Binding CurrentActiveTimer}"
                                             Background="Transparent" BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Hidden">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Margin" Value="0,0,8,0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="Bd" 
                                                                    Background="#0CFFFFFF"
                                                                    BorderBrush="#19FFFFFF"
                                                                    BorderThickness="1"
                                                                    CornerRadius="16"
                                                                    Padding="12,6"
                                                                    Cursor="Hand">
                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                    <!-- 正在运行提示点 -->
                                                                    <Ellipse x:Name="RunningDot" Width="6" Height="6" Fill="#6366F1" Margin="0,0,6,0" Visibility="Collapsed">
                                                                        <Ellipse.Triggers>
                                                                            <EventTrigger RoutedEvent="Loaded">
                                                                                <BeginStoryboard>
                                                                                    <Storyboard RepeatBehavior="Forever">
                                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1.0" To="0.3" Duration="0:0:1" AutoReverse="True"/>
                                                                                    </Storyboard>
                                                                                </BeginStoryboard>
                                                                            </EventTrigger>
                                                                        </Ellipse.Triggers>
                                                                    </Ellipse>
                                                                    <TextBlock x:Name="TxtName" Text="{Binding TimerName}" FontSize="12" Foreground="#9CA3AF"/>
                                                                    <!-- 附加组删除按钮（主番茄钟不显示） -->
                                                                    <TextBlock Text="×" FontSize="13" FontWeight="SemiBold" Foreground="#EF4444"
                                                                               Width="18" Height="18"
                                                                               TextAlignment="Center" LineHeight="18"
                                                                               VerticalAlignment="Center" Cursor="Hand"
                                                                               Margin="6,0,0,0" Padding="0"
                                                                               MouseLeftButtonDown="RemoveTimerButton_Click"
                                                                               Tag="{Binding}">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Opacity" Value="0.4"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding TimerName}" Value="主番茄钟">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                                                                                        <Setter Property="Opacity" Value="1.0"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding IsStarted}" Value="True">
                                                                    <Setter TargetName="RunningDot" Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Path=(utils:VisualEffects.IsReducingEffects), RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True">
                                                                    <Setter TargetName="RunningDot" Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#266366F1"/>
                                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#6366F1"/>
                                                                    <Setter TargetName="TxtName" Property="Foreground" Value="White"/>
                                                                    <Setter TargetName="TxtName" Property="FontWeight" Value="SemiBold"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#19FFFFFF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </ScrollViewer>

                                <Button Grid.Column="1" Content="＋" 
                                        Style="{StaticResource SecondaryButton}" 
                                        Command="{Binding AddAdditionalTimerCommand}"
                                        Width="32" Height="32" Padding="0" FontSize="16"
                                        ToolTip="添加附加番茄钟" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <!-- ========== Row 5: 底部功能栏 ========== -->
            <Border Grid.Row="5" BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,16,16">
                <Grid Margin="20,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Style="{StaticResource SecondaryButton}"
                            Content="📋 历史记录"
                            Command="{Binding OpenHistoryCommand}"
                            HorizontalAlignment="Left"/>

                    <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                            Content="📊 每日总结"
                            Command="{Binding OpenDailySummaryCommand}"
                            HorizontalAlignment="Center"/>

                    <Button Grid.Column="2" Style="{StaticResource SecondaryButton}"
                            Content="⚙ 设置 / 主题"
                            Command="{Binding OpenSettingsCommand}"
                            HorizontalAlignment="Right"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
