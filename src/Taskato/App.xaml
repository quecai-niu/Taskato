<Application x:Class="Taskato.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Taskato.Converters"
             Startup="Application_Startup"
             ShutdownMode="OnExplicitShutdown">
    <!--
        ShutdownMode="OnExplicitShutdown":
        不在关闭主窗口时自动退出应用，因为我们需要支持最小化到托盘继续运行。
        只有用户点击托盘菜单的"退出"才会真正关闭应用。
        
        Startup 事件而非 StartupUri:
        不直接指定启动窗体，改用代码控制启动流程（先初始化数据库等服务）。
    -->
    <Application.Resources>
        <ResourceDictionary>
            <!-- ============================================
                 全局转换器（供所有窗体使用）
                 ============================================ -->
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:TaskTimeDisplayConverter x:Key="TaskTimeDisplayConverter"/>
            <converters:IntToBoolConverter x:Key="IntToBoolConverter"/>

            <!-- ============================================
                 全局颜色常量（主题色系）
                 这些被 Themes 键覆盖时可实现换肤
                 ============================================ -->

            <!-- 主题渐变色（紫色为默认主题） -->
            <Color x:Key="ThemePrimaryColor">#6366F1</Color>
            <Color x:Key="ThemeSecondaryColor">#A855F7</Color>

            <!-- 基于主题色的画刷 -->
            <SolidColorBrush x:Key="ThemePrimaryBrush" Color="{StaticResource ThemePrimaryColor}"/>
            <LinearGradientBrush x:Key="ThemeGradientBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource ThemePrimaryColor}" Offset="0"/>
                <GradientStop Color="{StaticResource ThemeSecondaryColor}" Offset="1"/>
            </LinearGradientBrush>

            <!-- 窗体背景色 -->
            <Color x:Key="BackgroundDark">#1A1A2E</Color>
            <Color x:Key="BackgroundDarker">#16162A</Color>
            <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundDark}"/>
            <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource BackgroundDark}" Offset="0"/>
                <GradientStop Color="{StaticResource BackgroundDarker}" Offset="1"/>
            </LinearGradientBrush>

            <!-- 文字颜色 -->
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E0E0E0"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#888888"/>
            <SolidColorBrush x:Key="TextMutedBrush" Color="#555555"/>

            <!-- 控件背景/边框 -->
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#0DFFFFFF"/>
            <SolidColorBrush x:Key="InputBackgroundBrush" Color="#0FFFFFFF"/>
            <SolidColorBrush x:Key="InputBorderBrush" Color="#1AFFFFFF"/>
            <SolidColorBrush x:Key="SeparatorBrush" Color="#0FFFFFFF"/>

            <!-- 状态颜色 -->
            <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E"/>
            <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
            <SolidColorBrush x:Key="DangerBrush" Color="#EF4444"/>

            <!-- 优先级特定活力色彩 (V2 Phase 1 精确参数) -->
            <SolidColorBrush x:Key="Pri3Brush" Color="#FF4757"/> <!-- 紧急: 西瓜红 -->
            <SolidColorBrush x:Key="Pri2Brush" Color="#FFA502"/> <!-- 高: 活力橙 -->
            <SolidColorBrush x:Key="Pri1Brush" Color="#2ED573"/> <!-- 中: 明亮绿 -->
            <SolidColorBrush x:Key="Pri0Brush" Color="#747D8C"/> <!-- 无: 石板灰 -->

            <!-- ============================================
                 全局字体设置
                 ============================================ -->
            <FontFamily x:Key="AppFont">Microsoft YaHei UI, Segoe UI</FontFamily>

            <!-- ============================================
                 通用控件样式
                 ============================================ -->

            <!-- 主按钮样式（渐变紫色背景） -->
            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource ThemeGradientBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding" Value="20,10"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="10"
                                    Padding="{TemplateBinding Padding}"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="translateTransform"/>
                                </Border.RenderTransform>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="{DynamicResource ThemePrimaryColor}"
                                                              BlurRadius="15" ShadowDepth="4" Opacity="0.4"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 次要按钮样式（半透明背景 + 边框） -->
            <Style x:Key="SecondaryButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
                <Setter Property="Foreground" Value="#CCCCCC"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding" Value="20,10"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#1FFFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 危险按钮样式（红色调） -->
            <Style x:Key="DangerButton" TargetType="Button">
                <Setter Property="Background" Value="#1FEF4444"/>
                <Setter Property="Foreground" Value="#F87171"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding" Value="20,10"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="#26EF4444"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#33EF4444"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 文本输入框样式 -->
            <Style x:Key="DarkTextBox" TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="2,0"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="border" Property="BorderBrush" Value="#806366F1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 极简暗色单选按钮样式 -->
            <Style x:Key="DarkRadioButton" TargetType="RadioButton">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border Background="Transparent" Padding="4">
                                <StackPanel Orientation="Horizontal">
                                    <Grid Width="16" Height="16">
                                        <Ellipse x:Name="OuterCircle" Stroke="{StaticResource TextMutedBrush}" StrokeThickness="1"/>
                                        <Ellipse x:Name="InnerDot" Fill="{DynamicResource ThemePrimaryBrush}" Margin="4" Opacity="0"/>
                                    </Grid>
                                    <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="OuterCircle" Property="Stroke" Value="{DynamicResource ThemePrimaryBrush}"/>
                                    <Setter TargetName="OuterCircle" Property="StrokeThickness" Value="2"/>
                                    <Setter TargetName="InnerDot" Property="Opacity" Value="1"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="OuterCircle" Property="Stroke" Value="{DynamicResource ThemePrimaryBrush}"/>
                                    <Setter Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 极简滚动条滑块样式 (V2 Phase 1) -->
            <Style x:Key="ModernScrollBarThumb" TargetType="{x:Type Thumb}">
                <Setter Property="OverridesDefaultStyle" Value="true"/>
                <Setter Property="IsTabStop" Value="false"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Thumb}">
                            <Border x:Name="rectangle"
                                    Background="#26FFFFFF"
                                    CornerRadius="2.5"
                                    Margin="0,0,0,0" />
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="true">
                                    <Setter TargetName="rectangle" Property="Background" Value="#4DFFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsDragging" Value="true">
                                    <Setter TargetName="rectangle" Property="Background" Value="#66FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 全局滚动条美化：去箭头、纤细化 (5px) -->
            <Style TargetType="{x:Type ScrollBar}">
                <Setter Property="OverridesDefaultStyle" Value="True"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Width" Value="5"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Grid x:Name="Bg" Background="Transparent" SnapsToDevicePixels="true">
                                <Track x:Name="PART_Track" IsDirectionReversed="true">
                                    <!-- 去掉 RepeatButton (箭头按钮) -->
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0" Focusable="False" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0" Focusable="False" />
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ModernScrollBarThumb}"/>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="Orientation" Value="Horizontal">
                        <Setter Property="Width" Value="Auto"/>
                        <Setter Property="Height" Value="5"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- 全局 ScrollViewer 样式重构：解决 17px 空白占用问题 -->
            <Style TargetType="{x:Type ScrollViewer}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollViewer}">
                            <Grid x:Name="Grid" Background="{TemplateBinding Background}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/> <!-- 关键：设为 Auto 紧贴边缘，不再预留 17px -->
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <ScrollContentPresenter x:Name="PART_ScrollContentPresenter" 
                                                        CanContentScroll="{TemplateBinding CanContentScroll}" 
                                                        CanHorizontallyScroll="False" 
                                                        CanVerticallyScroll="False" 
                                                        Content="{TemplateBinding Content}" 
                                                        ContentTemplate="{TemplateBinding ContentTemplate}" 
                                                        Grid.Column="0" Grid.Row="0" 
                                                        Margin="{TemplateBinding Padding}" 
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                <ScrollBar x:Name="PART_VerticalScrollBar" 
                                           AutomationProperties.AutomationId="VerticalScrollBar" 
                                           Cursor="Arrow" Grid.Column="1" 
                                           Maximum="{TemplateBinding ScrollableHeight}" 
                                           Minimum="0" Grid.Row="0" 
                                           Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" 
                                           Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                           ViewportSize="{TemplateBinding ViewportHeight}"/>
                                <ScrollBar x:Name="PART_HorizontalScrollBar" 
                                           AutomationProperties.AutomationId="HorizontalScrollBar" 
                                           Cursor="Arrow" Grid.Column="0" 
                                           Maximum="{TemplateBinding ScrollableWidth}" 
                                           Minimum="0" Orientation="Horizontal" Grid.Row="1" 
                                           Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}" 
                                           Value="{Binding HorizontalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                           ViewportSize="{TemplateBinding ViewportWidth}"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 气泡风托盘菜单样式 (V2 Phase 1) -->
            <Style x:Key="BubbleTrayMenu" TargetType="ContextMenu">
                <Setter Property="Background" Value="#24242D"/>
                <Setter Property="BorderBrush" Value="#0FFFFFFF"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContextMenu">
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="14">
                                <StackPanel IsItemsHost="True" Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="BubbleTrayMenuItem" TargetType="MenuItem">
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Border x:Name="Bd" Padding="{TemplateBinding Padding}" Background="Transparent" CornerRadius="8">
                                <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="BubbleTraySeparator" TargetType="Separator">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Separator">
                            <Border Background="#0AFFFFFF" Height="1" Margin="4,4"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============================================
                 V2 深度优化样式 (窗口控制 & 微型按钮)
                 ============================================ -->
            
            <!-- 可爱的 Windows 风格窗口控制按钮 -->
            <Style x:Key="CuteWinBtn" TargetType="Button">
                <Setter Property="Width" Value="28"/>
                <Setter Property="Height" Value="28"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#1AFFFFFF"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 
                 【Q弹果冻窗口控制】 JellyWinBtn
                 方案 4：胶囊型集成化设计。
            -->
            <Style x:Key="JellyCapsuleStyle" TargetType="Border">
                <Setter Property="Background" Value="#0DFFFFFF"/>
                <Setter Property="CornerRadius" Value="15"/>
                <Setter Property="Padding" Value="2"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="BorderBrush" Value="#0FFFFFFF"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <!-- 
                 【子窗体统一外壳样式】 SubWindowBorderStyle
                 方案 4：彩色外溢描边 (Color Spill)
                 用于：设置、历史、详情、对话框等
            -->
            <!-- 
                 【任务输入框容器】 TaskInputCapsuleStyle
                 方案 1：极简流体胶囊
            -->
            <Style x:Key="TaskInputCapsuleStyle" TargetType="Border">
                <Setter Property="Height" Value="56"/>
                <Setter Property="CornerRadius" Value="28"/>
                <Setter Property="Background" Value="#0DFFFFFF"/>
                <Setter Property="BorderBrush" Value="#1AFFFFFF"/>
                <Setter Property="BorderThickness" Value="1.2"/>
                <Setter Property="Margin" Value="20,0,20,24"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#14FFFFFF"/>
                        <Setter Property="BorderBrush" Value="#33FFFFFF"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- 优先级圆点 ListBox 样式 -->
            <Style x:Key="PriorityDotListBoxStyle" TargetType="ListBox">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="ItemsPanel">
                    <Setter.Value>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBox">
                            <ItemsPresenter/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PriorityDotItemStyle" TargetType="ListBoxItem">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="dot" Width="11" Height="11" CornerRadius="6" Margin="4,0"
                                    Background="{TemplateBinding Foreground}" Cursor="Hand"
                                    ToolTip="{TemplateBinding ToolTip}"/>
                            <ControlTemplate.Triggers>
                                <!-- 选中状态：放大、加描边、加外溢光 -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="dot" Property="BorderBrush" Value="White"/>
                                    <Setter TargetName="dot" Property="BorderThickness" Value="1.5"/>
                                    <Setter TargetName="dot" Property="Width" Value="14"/>
                                    <Setter TargetName="dot" Property="Height" Value="14"/>
                                    <Setter TargetName="dot" Property="CornerRadius" Value="7"/>
                                    <Setter TargetName="dot" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect BlurRadius="10" Color="White" Opacity="0.4" ShadowDepth="0"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="dot" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 圆形霓虹添加按钮 -->
            <Style x:Key="AddRoundButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="42"/>
                <Setter Property="Height" Value="42"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Border x:Name="bg" CornerRadius="21">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="{DynamicResource ThemePrimaryColor}" Offset="0"/>
                                            <GradientStop Color="{DynamicResource ThemeSecondaryColor}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="{DynamicResource ThemePrimaryColor}" BlurRadius="15" ShadowDepth="2" Opacity="0.5"/>
                                    </Border.Effect>
                                </Border>
                                <TextBlock Text="+" Foreground="White" FontSize="24" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Opacity" Value="0.9"/>
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="bg" Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1.1" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetName="bg" Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1.1" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            </Style>

            <!-- 
                 【子窗体统一外壳样式】 SubWindowBorderStyle
                 方案 4：彩色外溢描边 (Color Spill)
                 用于：设置、历史、详情、对话框等
            -->
            <Style x:Key="SubWindowBorderStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="20"/>
                <Setter Property="Margin" Value="40"/> <!-- 关键：预留边距以显示外发光阴影，防止被窗口边界裁剪 -->
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1F1A2E" Offset="0"/>
                            <GradientStop Color="#11111F" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="BorderBrush">
                    <Setter.Value>
                        <SolidColorBrush Color="{DynamicResource ThemePrimaryColor}" Opacity="0.4"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="{DynamicResource ThemePrimaryColor}" BlurRadius="50" ShadowDepth="0" Opacity="0.5" RenderingBias="Quality"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 
                 【主窗体外壳样式】 MainWindowBorderStyle
                 同步子窗体的霓虹光晕效果
            -->
            <Style x:Key="MainWindowBorderStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="Margin" Value="40"/>
                <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}"/>
                <Setter Property="BorderThickness" Value="1.2"/>
                <Setter Property="BorderBrush">
                    <Setter.Value>
                        <SolidColorBrush Color="{DynamicResource ThemePrimaryColor}" Opacity="0.3"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="{DynamicResource ThemePrimaryColor}" BlurRadius="60" ShadowDepth="0" Opacity="0.4" RenderingBias="Quality"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="JellyWinBtn" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding" Value="12,5"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <!-- 底层：普通状态 -->
                                <Border x:Name="normalBd" Background="{TemplateBinding Background}" CornerRadius="13"/>
                                <!-- 悬停层：使用动态主题色，通过 Opacity 动画实现平滑过渡 -->
                                <Border x:Name="hoverBd" Background="{DynamicResource ThemePrimaryBrush}" CornerRadius="13" Opacity="0"/>
                                
                                <Border x:Name="contentContainer" Background="Transparent" CornerRadius="13" Padding="{TemplateBinding Padding}" RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/>
                                    </Border.RenderTransform>
                                    <ContentPresenter x:Name="cp" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="hoverBd" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1.15" Duration="0:0:0.3">
                                                    <DoubleAnimation.EasingFunction><BackEase Amplitude="1" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1.15" Duration="0:0:0.3">
                                                    <DoubleAnimation.EasingFunction><BackEase Amplitude="1" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <!-- 文字变白 -->
                                                <ColorAnimation Storyboard.TargetName="cp" Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)" To="White" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="hoverBd" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.3"/>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.3"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="JellyWinMinBtn" TargetType="Button" BasedOn="{StaticResource JellyWinBtn}">
                <Setter Property="Content" Value="—"/>
            </Style>

            <Style x:Key="JellyWinMaxBtn" TargetType="Button" BasedOn="{StaticResource JellyWinBtn}">
                <Setter Property="Content" Value="▢"/>
            </Style>

            <!-- 
                 【番茄钟状态标签】 PomodoroStatusTagStyle
                 方案 2：霓虹辉光 (Neon Pulse)
            -->
            <Style x:Key="PomodoroStatusTagStyle" TargetType="ContentControl">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContentControl">
                            <Grid x:Name="container">
                                <!-- 1. 脉冲扩散层 (水波纹) -->
                                <Border x:Name="ripple" 
                                        BorderThickness="1.5" 
                                        CornerRadius="100"
                                        Opacity="0"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="{DynamicResource ThemePrimaryColor}" Offset="0"/>
                                            <GradientStop Color="{DynamicResource ThemeSecondaryColor}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="rippleScale" ScaleX="1" ScaleY="1"/>
                                    </Border.RenderTransform>
                                </Border>

                                <!-- 2. 主体背景层 (带霓虹外发光) -->
                                <Border x:Name="mainBd" 
                                        Background="#1E1B4B" 
                                        BorderThickness="1.2"
                                        CornerRadius="100">
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="{DynamicResource ThemePrimaryColor}" Offset="0"/>
                                            <GradientStop Color="{DynamicResource ThemeSecondaryColor}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <Border.Effect>
                                        <!-- 使用 Quality 偏好，且不包含文字以避免模糊 -->
                                        <DropShadowEffect Color="{DynamicResource ThemePrimaryColor}" 
                                                          BlurRadius="12" ShadowDepth="0" Opacity="0.6"
                                                          RenderingBias="Quality"/>
                                    </Border.Effect>
                                </Border>

                                <!-- 3. 内容层 (增加内边距解决拥挤感) -->
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16,5"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <!-- 水波扩散动画 -->
                                            <DoubleAnimation Storyboard.TargetName="rippleScale" Storyboard.TargetProperty="ScaleX" From="1" To="1.6" Duration="0:0:2.5">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="rippleScale" Storyboard.TargetProperty="ScaleY" From="1" To="1.6" Duration="0:0:2.5">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ripple" Storyboard.TargetProperty="Opacity" From="0.7" To="0" Duration="0:0:2.5">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            
                                            <!-- 主体微弱呼吸 -->
                                            <DoubleAnimation Storyboard.TargetName="mainBd" Storyboard.TargetProperty="(UIElement.Effect).Opacity" 
                                                             From="0.6" To="0.3" Duration="0:0:1.25" AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="JellyWinCloseBtn" TargetType="Button" BasedOn="{StaticResource JellyWinBtn}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Border x:Name="normalBd" Background="{TemplateBinding Background}" CornerRadius="13"/>
                                <!-- 关闭按钮悬停使用固定的红色 -->
                                <Border x:Name="hoverBd" Background="#EF4444" CornerRadius="13" Opacity="0"/>
                                
                                <Border x:Name="contentContainer" Background="Transparent" CornerRadius="13" Padding="{TemplateBinding Padding}" RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/>
                                    </Border.RenderTransform>
                                    <ContentPresenter x:Name="cp" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="hoverBd" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1.15" Duration="0:0:0.3">
                                                    <DoubleAnimation.EasingFunction><BackEase Amplitude="1" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1.15" Duration="0:0:0.3">
                                                    <DoubleAnimation.EasingFunction><BackEase Amplitude="1" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ColorAnimation Storyboard.TargetName="cp" Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)" To="White" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="hoverBd" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.3"/>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.3"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 窗口关闭专用按钮（悬浮变红） -->
            <Style x:Key="CuteWinCloseBtn" TargetType="Button" BasedOn="{StaticResource CuteWinBtn}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 
                 【Q弹果冻图标按钮】 JellyIconBtn
                 完美复刻 HTML 预览版方案 1 的物理质感。
                 - 悬停：底座由 15% 透明度变为实色，符号变白，整体放大 1.15 倍并顺时针旋转 5 度。
                 - 物理感：使用 BackEase 缓动函数实现类似弹性回弹的效果。
                 - 阴影：动态阴影随悬停显现。
            -->
            <Style x:Key="JellyIconBtn" TargetType="Button">
                <Setter Property="Width" Value="32"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                                <!-- 容器：整体进行几何变换 -->
                                <Grid x:Name="container" RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/>
                                            <RotateTransform x:Name="rotate" Angle="0"/>
                                        </TransformGroup>
                                    </Grid.RenderTransform>

                                    <!-- 下层：果冻底座 -->
                                    <Border x:Name="bd"
                                            Background="{DynamicResource ThemePrimaryBrush}"
                                            Opacity="0.15"
                                            CornerRadius="10">
                                        <Border.Effect>
                                            <DropShadowEffect x:Name="shadow" Color="{DynamicResource ThemePrimaryColor}"
                                                              BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                                        </Border.Effect>
                                    </Border>

                                    <!-- 上层：矢量加减符号 (摒弃文字，改用绘图) -->
                                    <Path x:Name="symbolPath"
                                          Stroke="{DynamicResource ThemePrimaryBrush}"
                                          StrokeThickness="2.5"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="8" Stretch="Uniform"/>
                                </Grid>

                            <ControlTemplate.Triggers>
                                <!-- 根据 Content 自动切换 Path 数据 -->
                                <Trigger Property="Content" Value="＋">
                                    <Setter TargetName="symbolPath" Property="Data" Value="M 0,5 H 10 M 5,0 V 10"/>
                                </Trigger>
                                <Trigger Property="Content" Value="－">
                                    <Setter TargetName="symbolPath" Property="Data" Value="M 0,5 H 10"/>
                                </Trigger>

                                <!-- 鼠标进入：执行进入动画 (HoverOn) -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard x:Name="HoverOn_Begin">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction><BackEase Amplitude="0.4" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <!-- 符号变白 -->
                                                <ColorAnimation Storyboard.TargetName="symbolPath" Storyboard.TargetProperty="(Path.Stroke).(SolidColorBrush.Color)" To="White" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1.15" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction><BackEase Amplitude="0.8" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1.15" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction><BackEase Amplitude="0.8" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="rotate" Storyboard.TargetProperty="Angle" To="5" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="BlurRadius" To="12" Duration="0:0:0.25"/>
                                                <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="Opacity" To="0.4" Duration="0:0:0.25"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="HoverOn_Begin"/>
                                    </Trigger.ExitActions>
                                </Trigger>

                                <!-- 点击按下：产生按压感 -->
                                <Trigger Property="IsPressed" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard x:Name="PressOn_Begin">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="0.85" Duration="0:0:0.1"/>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="0.85" Duration="0:0:0.1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="PressOn_Begin"/>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============================================
                 矢量图标库 (V2)
                 ============================================ -->
