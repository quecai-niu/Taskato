            <Geometry x:Key="IconHistory">M18,2h-3.18C14.4,0.84,13.3,0,12,0S9.6,0.84,9.18,2H6C4.9,2,4,2.9,4,4v16c0,1.1,0.9,2,2,2h12c1.1,0,2-0.9,2-2V4C20,2.9,19.1,2,18,2z M12,2c0.55,0,1,0.45,1,1s-0.45,1-1,1s-1-0.45-1-1S11.45,2,12,2z M18,20H6V4h2v3h8V4h2V20z</Geometry>
            <Geometry x:Key="IconExport">M19,9h-4V3H9v6H5l7,7L19,9z M5,18v2h14v-2H5z</Geometry>

            <!-- 极简微型图标按钮（通用，保留备用） -->

        </ResourceDictionary>
    </Application.Resources>
</Application>
